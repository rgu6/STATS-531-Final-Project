        "#| echo: false\n",
        "#| label: fitbit-missing\n",
        "# for each participant, get the mean value of the fitbitStepsMissing column (0 = step count recorded, 1 = missing) for a percent of how many hourly windows we have steps missing for.\n",
        "fitbit_steps_missing_percent = (fitbit_hourly.groupby('PARTICIPANTIDENTIFIER')['fitbitStepsMissing'].mean() * 100).sort_values(ascending=True)\n",
