        "            \"stage2_particles\": 20,\n",
        "            \"stage1_if2_iterations\": 1,\n",
        "            \"stage2_if2_iterations\": 1,\n",
        "            \"stage1_cooling_fraction\": 0.50,\n",
        "            \"stage2_cooling_fraction\": 0.50,\n",
        "            \"stage1_rw_sd_scale\": 0.02,\n",
        "            \"stage2_rw_sd_scale\": 0.02,\n",
        "            \"cooling_fraction\": 0.50,\n",
        "            \"rw_sd_scale\": 0.02,\n",
        "            \"stage1_eval_particles\": 20,\n",
        "            \"stage2_eval_particles\": 20,\n",
        "            \"stage1_eval_reps\": 1,\n",
        "            \"stage2_eval_reps\": 1,\n",
