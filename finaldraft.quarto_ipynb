        "            {\n",
        "                \"Parameter\": parameter_name,\n",
        "                \"Low\": float(bounds[0]),\n",
        "                \"High\": float(bounds[1]),\n",
        "            }\n",
        "            for parameter_name, bounds in RESOLVED_CONFIG[\"search_windows\"].items()\n",
        "        ]\n",
        "    )\n",
        "    .loc[\n",
        "        lambda df: ~df[\"Parameter\"].isin(\n",
        "            [\n",
        "                \"eta_wear_lag1\",\n",
        "                \"phi1\",\n",
        "                \"phi2\",\n",
        "                \"phi24\",\n",
        "                \"wear_phi\",\n",
        "                \"wear_sigma\",\n",
        "            ]\n",
        "        )\n",
        "    ]\n",
        "    .sort_values(\"Parameter\")\n",
        "    .reset_index(drop=True)\n",
        ")\n",
        "\n",
        "search_window_table_render = search_window_display.copy()\n",
        "for column_name in (\"Low\", \"High\"):\n",
        "    search_window_table_render[column_name] = pd.to_numeric(\n",
        "        search_window_table_render[column_name],\n",
        "        errors=\"coerce\",\n",
        "    ).map(lambda value: f\"{value:.3f}\" if pd.notna(value) else \"\")\n",
        "\n",
        "search_window_table_path = (\n",
        "    CACHE_PATHS[\"report_exports\"] / \"plots\" / \"inference_search_window_table_inline.png\"\n",
        ")\n",
        "search_window_table_path.parent.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8.2, 5.6))\n",
        "ax.axis(\"off\")\n",
        "ax.set_position([0.0, 0.0, 1.0, 1.0])\n",
        "table = ax.table(\n",
        "    cellText=search_window_table_render.values,\n",
        "    colLabels=search_window_table_render.columns,\n",
        "    cellLoc=\"center\",\n",
        "    colWidths=[0.56, 0.22, 0.22],\n",
        "    bbox=[0.02, 0.02, 0.96, 0.96],\n",
        ")\n",
        "table.auto_set_font_size(False)\n",
        "table.set_fontsize(32)\n",
        "\n",
        "for (row, col), cell in table.get_celld().items():\n",
        "    cell.set_edgecolor(\"#444444\")\n",
        "    cell.set_linewidth(0.4)\n",
        "    if row == 0:\n",
        "        cell.set_text_props(weight=\"bold\")\n",
        "        cell.set_facecolor(\"#f3f4f6\")\n",
        "    elif col == 0:\n",
        "        cell.set_text_props(ha=\"left\")\n",
        "\n",
        "fig.savefig(search_window_table_path, dpi=300, bbox_inches=\"tight\", pad_inches=0.02, facecolor=\"white\")\n",
        "plt.close(fig)"
      ],
      "id": "inference-search-window-table-build",
      "execution_count": null,
      "outputs": []
    },
