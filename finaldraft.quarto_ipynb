        "        ax.grid(True, alpha=0.25)\n",
        "    handles, labels = axes[0].get_legend_handles_labels()\n",
        "    if handles:\n",
        "        axes[0].legend(handles, labels, title=\"pooling\", fontsize=13)\n",
        "    plt.tight_layout()\n",
        "    plt.show()"
      ],
