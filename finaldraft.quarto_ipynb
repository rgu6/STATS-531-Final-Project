      "source": [
        "#| echo: false\n",
        "#| label: results-model-summary-table\n",
        "\n",
        "if aggregate_model_comparison.empty:\n",
        "    print(\"No aggregate benchmark summaries are available for the current configuration.\")\n",
        "else:\n",
        "    model_summary_display = (\n",
        "        aggregate_model_comparison.assign(\n",
        "            model=lambda df: df[\"model_family\"].map(model_label),\n",
        "            pooling=lambda df: df[\"pooling_mode\"].map(pooling_label),\n",
        "            estimate=lambda df: df[\"estimate_type\"].map(estimate_label),\n",
        "        )\n",
        "        .loc[\n",
        "            :,\n",
        "            [\n",
        "                \"model\",\n",
        "                \"pooling\",\n",
        "                \"estimate\",\n",
        "                \"mean_panel_unit_loglik\",\n",
        "                \"hourly_masked_rmse\",\n",
        "                \"heldout_subtotal_rmse_sqrtm\",\n",
        "            ],\n",
        "        ]\n",
        "        .rename(\n",
        "            columns={\n",
