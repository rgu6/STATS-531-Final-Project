        "#| echo: false\n",
        "#| label: results-model-summary-table\n",
        "\n",
        "if aggregate_model_comparison.empty:\n",
        "    print(\"No aggregate benchmark summaries are available for the current configuration.\")\n",
        "else:\n",
        "    comparison_source = aggregate_model_comparison.copy()\n",
        "    comparison_source[\"model_family\"] = comparison_source[\"model_family\"].astype(str)\n",
        "    comparison_source[\"pooling_mode\"] = comparison_source[\"pooling_mode\"].astype(str)\n",
        "    comparison_source[\"estimate_type\"] = comparison_source[\"estimate_type\"].astype(str)\n",
        "    comparison_source = comparison_source.loc[comparison_source[\"estimate_type\"] == \"filter\"].copy()\n",
        "\n",
        "    smoother_summary_path = CACHE_PATHS[\"root\"] / \"smoother_report_exports\" / \"jax_masked_ar1_v1\" / \"combined_summary.csv\"\n",
        "    smoother_summary = pd.DataFrame()\n",
        "    if smoother_summary_path.exists():\n",
        "        smoother_summary = pd.read_csv(smoother_summary_path)\n",
        "        if not smoother_summary.empty:\n",
        "            smoother_summary[\"model_family\"] = smoother_summary[\"model_family\"].astype(str)\n",
        "            smoother_summary[\"pooling_mode\"] = smoother_summary[\"pooling_mode\"].astype(str)\n",
        "            smoother_summary[\"estimate_type\"] = \"smoothed\"\n",
        "\n",
        "    model_column_order = [\n",
        "        (\"ar1\", \"global_shared_k\", \"filter\", \"globalfilter\"),\n",
        "        (\"ar1\", \"global_shared_k\", \"smoothed\", \"globalsmooth\"),\n",
        "        (\"ar1\", \"partial_pooled_k\", \"filter\", \"partialfilter\"),\n",
        "        (\"ar1\", \"partial_pooled_k\", \"smoothed\", \"partialsmooth\"),\n",
        "        (\"ar1\", \"unit_specific\", \"filter\", \"personalfilter\"),\n",
        "        (\"ar1\", \"unit_specific\", \"smoothed\", \"personalsmooth\"),\n",
        "        (\"arma_aic\", \"not_applicable\", \"filter\", \"ARMA\"),\n",
        "    ]\n",
        "\n",
        "    metric_lookup: dict[tuple[str, str, str], dict[str, object]] = {}\n",
        "    for _, row in comparison_source.iterrows():\n",
        "        model_key = (str(row[\"model_family\"]), str(row[\"pooling_mode\"]), \"filter\")\n",
        "        metric_lookup[model_key] = {\n",
        "            \"Avg logLik\": row.get(\"mean_panel_unit_loglik\"),\n",
        "            \"Hourly RMSE\": row.get(\"hourly_masked_rmse\"),\n",
        "            \"RMSE Subtotal\": row.get(\"heldout_subtotal_rmse_sqrtm\"),\n",
        "            \"Avg hr corr\": row.get(\"hourly_masked_correlation\"),\n",
        "            \"Avg day corr\": row.get(\"daily_correlation\"),\n",
        "        }\n",
        "\n",
        "    if not smoother_summary.empty:\n",
        "        for _, row in smoother_summary.iterrows():\n",
        "            model_key = (str(row[\"model_family\"]), str(row[\"pooling_mode\"]), \"smoothed\")\n",
        "            metric_lookup[model_key] = {\n",
        "                \"Avg logLik\": row.get(\"avg_log_likelihood\"),\n",
        "                \"Hourly RMSE\": row.get(\"hourly_rmse\"),\n",
        "                \"RMSE Subtotal\": row.get(\"rmse_subtotal_participant_mean\"),\n",
        "                \"Avg hr corr\": row.get(\"avg_hourly_correlation\"),\n",
        "                \"Avg day corr\": row.get(\"avg_daily_correlation\"),\n",
        "            }\n",
        "\n",
        "    if not parameter_model_summary.empty:\n",
        "        parameter_source = parameter_model_summary.copy()\n",
        "        parameter_source[\"model_family\"] = parameter_source[\"model_family\"].astype(str)\n",
        "        parameter_source[\"pooling_mode\"] = parameter_source[\"pooling_mode\"].astype(str)\n",
        "        smoother_supported_keys = {\n",
        "            (model_family, pooling_mode, estimate_type)\n",
        "            for model_family, pooling_mode, estimate_type, _ in model_column_order\n",
        "        }\n",
        "        for _, row in parameter_source.iterrows():\n",
        "            filter_key = (str(row[\"model_family\"]), str(row[\"pooling_mode\"]), \"filter\")\n",
        "            parameter_metrics = {\n",
        "                \"Avg phi\": row.get(\"mean_phi\"),\n",
        "                \"Avg sigma\": row.get(\"mean_sigma\"),\n",
        "                \"Avg k\": row.get(\"mean_k\"),\n",
        "                \"SD k\": row.get(\"sd_k\"),\n",
        "            }\n",
        "            metric_lookup.setdefault(filter_key, {}).update(parameter_metrics)\n",
        "            smooth_key = (str(row[\"model_family\"]), str(row[\"pooling_mode\"]), \"smoothed\")\n",
        "            if smooth_key in smoother_supported_keys:\n",
        "                metric_lookup.setdefault(smooth_key, {}).update(parameter_metrics)\n",
        "\n",
        "    row_order = [\n",
        "        \"Avg logLik\",\n",
        "        \"RMSE Subtotal\",\n",
        "        \"Avg hr corr\",\n",
        "        \"Avg day corr\",\n",
        "        \"Avg phi\",\n",
        "        \"Avg sigma\",\n",
        "        \"Avg k\",\n",
        "        \"SD k\",\n",
        "    ]\n",
        "\n",
        "    combined_summary_display = pd.DataFrame({\"Metric\": row_order})\n",
        "    for model_family, pooling_mode, estimate_type, column_label in model_column_order:\n",
        "        model_metrics = metric_lookup.get((model_family, pooling_mode, estimate_type), {})\n",
        "        combined_summary_display[column_label] = [model_metrics.get(metric_name, np.nan) for metric_name in row_order]\n",
        "\n",
        "    combined_summary_render = combined_summary_display.copy()\n",
        "    for column_name in combined_summary_render.columns:\n",
        "        if column_name == \"Metric\":\n",
        "            continue\n",
        "        combined_summary_render[column_name] = pd.to_numeric(\n",
        "            combined_summary_render[column_name],\n",
        "            errors=\"coerce\",\n",
        "        ).map(lambda value: f\"{value:.3f}\" if pd.notna(value) else \"\")\n",
        "\n",
        "    fig_height = 1.6 * (len(combined_summary_render) + 1) + 0.6\n",
        "    fig, ax = plt.subplots(figsize=(16, fig_height))\n",
        "    ax.axis(\"off\")\n",
        "    table = ax.table(\n",
        "        cellText=combined_summary_render.values,\n",
        "        colLabels=combined_summary_render.columns,\n",
        "        cellLoc=\"center\",\n",
        "        loc=\"center\",\n",
        "    )\n",
        "    table.auto_set_font_size(False)\n",
        "    table.set_fontsize(36)\n",
        "    table.scale(4.3, 5.5)\n",
        "    try:\n",
        "        table.auto_set_column_width(col=list(range(len(combined_summary_render.columns))))\n",
        "    except Exception:\n",
        "        pass\n",
        "\n",
        "    for (row, col), cell in table.get_celld().items():\n",
        "        cell.set_edgecolor(\"#444444\")\n",
        "        cell.set_linewidth(0.4)\n",
        "        if row == 0:\n",
        "            cell.set_text_props(weight=\"bold\")\n",
        "            cell.set_facecolor(\"#f3f4f6\")\n",
        "        elif col == 0:\n",
        "            cell.set_text_props(ha=\"left\")\n",
        "\n",
        "    plt.show()"
      ],
      "id": "results-model-summary-table",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "All the POMP models performed substantially better than the baseline ARMA models. The log-likelihoods appear much worse, but this is to be expected. The POMP models are not trying to estimate the data, they're trying to estimate an underlying latent that always upper bounds the data. So while ARMA has a much lower log likelihood, it just tries to fit itself to observed rewards, and hence performs much worse on the normalized benchmark proposed for tracking prediction ability.\n",
        "\n",
        "The \"avg hr corr\" and \"avg day corr\" are average correlations between the prediction and held-out masked data on the hourly level, and on the daily subtotal level respectively. The daily level is more relevant to the task of predicting daily level rewards, but the contrast with the hourly is of note: While these models may predict a single hour poorly, their ability to predict a larger sum of values improves relatively.\n",
        "\n",
        "For the filtered models, they perform very similarly. The partial pooling performs slightly better on the RMSE Subtotal, but 807 vs 809 is likely within range of Monte Carlo noise. The same trend can be seen in the smoothing case; the personal smoother now performs 0.7 RMSE Subtotal units better.\n",
        "\n",
        "The smoothers consistently gain a modest boost over the filtered versions, suggesting that the future information does help predict unseen prior information. Interestingly, their daily correlation decreases substantially! We aren't sure why this is. It also presents more of a tradeoff than expected between a filtered estimate and a smoother estimate. "
      ],
      "id": "26aa68d9"
    },
    {
      "cell_type": "code",
