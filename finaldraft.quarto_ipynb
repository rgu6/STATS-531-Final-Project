        "            **shared,\n",
        "            \"RL\": 1,\n",
        "            \"device\": \"gpu\",\n",
        "            \"participant_set\": \"full_set\",\n",
        "            \"model_set\": \"smoke\",\n",
        "            \"pooling_mode\": \"all\",\n",
        "            \"panel_chunk_size\": 78,\n",
        "            \"stage1_starts\": 10,\n",
        "            \"stage2_starts\": 5,\n",
        "            \"stage1_keep_top\": 2,\n",
        "            \"stage2_keep_top\": 1,\n",
        "            \"stage1_particles\": 200,\n",
        "            \"stage2_particles\": 200,\n",
        "            \"stage1_if2_iterations\": 5,\n",
        "            \"stage2_if2_iterations\": 5,\n",
        "            \"stage1_cooling_fraction\": 0.90,\n",
        "            \"stage2_cooling_fraction\": 0.90,\n",
        "            \"stage1_rw_sd_scale\": 0.02,\n",
        "            \"stage2_rw_sd_scale\": 0.015,\n",
        "            \"cooling_fraction\": 0.90,\n",
        "            \"rw_sd_scale\": 0.02,\n",
        "            \"stage1_eval_particles\": 300,\n",
        "            \"stage2_eval_particles\": 200,\n",
        "            \"stage1_eval_reps\": 5,\n",
        "            \"stage2_eval_reps\": 5,\n",
        "            \"stage1_fresh_random_starts\": 0,\n",
        "            \"stage2_fresh_random_starts\": 0,\n",
        "            \"stage1_jittered_restarts\": 0,\n",
        "            \"stage2_jittered_restarts\": 1,\n",
