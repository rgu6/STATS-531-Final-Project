      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "#| label: compute-interface\n",
        "\n",
        "# COMPUTE INTERFACE / PARAMS\n",
        "# RL DEFAULTS AND RESOLVED CONFIG\n",
        "# DEVICE SETUP\n",
        "# EXPERIMENT REGISTRY\n",
        "\n",
        "import hashlib\n",
        "import json\n",
        "import os\n",
        "import sys\n",
        "from pathlib import Path\n",
        "\n",
        "import pandas as pd\n",
        "import yaml\n",
        "\n",
        "\n",
        "PROJECT_ROOT = Path.cwd().resolve()\n",
        "APP_CODE_ROOT = PROJECT_ROOT.parent / \"eda\"\n",
        "HELPERS_ROOT = PROJECT_ROOT / \"helpers\"\n",
        "\n",
        "if str(APP_CODE_ROOT) not in sys.path:\n",
        "    sys.path.insert(0, str(APP_CODE_ROOT))\n",
        "\n",
        "\n",
        "def _raw_params() -> dict:\n",
        "    parameter_keys = [\n",
        "        \"RL\",\n",
        "        \"device\",\n",
        "        \"cache_mode\",\n",
        "        \"cache_version\",\n",
        "        \"artifact_tag\",\n",
        "        \"participant_set\",\n",
        "        \"model_set\",\n",
        "        \"model_family\",\n",
        "        \"pooling_mode\",\n",
        "        \"covariate_mode\",\n",
        "        \"mask_regime\",\n",
        "        \"missing_fraction\",\n",
        "        \"mask_seed\",\n",
        "        \"n_mask_replicates\",\n",
        "        \"fit_scope\",\n",
        "        \"section_scope\",\n",
        "        \"global_seed\",\n",
        "        \"panel_chunk_size\",\n",
        "        \"stage1_starts\",\n",
        "        \"stage2_starts\",\n",
        "        \"stage1_keep_top\",\n",
        "        \"stage2_keep_top\",\n",
        "        \"stage1_particles\",\n",
        "        \"stage2_particles\",\n",
        "        \"stage1_if2_iterations\",\n",
        "        \"stage2_if2_iterations\",\n",
        "        \"stage1_cooling_fraction\",\n",
        "        \"stage2_cooling_fraction\",\n",
        "        \"stage1_rw_sd_scale\",\n",
        "        \"stage2_rw_sd_scale\",\n",
        "        \"cooling_fraction\",\n",
        "        \"rw_sd_scale\",\n",
        "        \"stage1_eval_particles\",\n",
        "        \"stage2_eval_particles\",\n",
        "        \"stage1_eval_reps\",\n",
        "        \"stage2_eval_reps\",\n",
        "        \"stage1_fresh_random_starts\",\n",
        "        \"stage2_fresh_random_starts\",\n",
        "        \"stage1_jittered_restarts\",\n",
        "        \"stage2_jittered_restarts\",\n",
        "        \"phi_window_low\",\n",
        "        \"phi_window_high\",\n",
        "        \"phi1_window_low\",\n",
        "        \"phi1_window_high\",\n",
        "        \"phi2_window_low\",\n",
        "        \"phi2_window_high\",\n",
        "        \"phi24_window_low\",\n",
        "        \"phi24_window_high\",\n",
        "        \"sigma_window_low\",\n",
        "        \"sigma_window_high\",\n",
        "        \"k_fitbit_window_low\",\n",
        "        \"k_fitbit_window_high\",\n",
        "        \"log_k_fitbit_window_low\",\n",
        "        \"log_k_fitbit_window_high\",\n",
        "        \"mu_log_k_fitbit_window_low\",\n",
        "        \"mu_log_k_fitbit_window_high\",\n",
        "        \"log_tau_log_k_fitbit_window_low\",\n",
        "        \"log_tau_log_k_fitbit_window_high\",\n",
        "        \"eta_wear_lag1_window_low\",\n",
        "        \"eta_wear_lag1_window_high\",\n",
        "        \"wear_phi_window_low\",\n",
        "        \"wear_phi_window_high\",\n",
        "        \"wear_sigma_window_low\",\n",
        "        \"wear_sigma_window_high\",\n",
        "    ]\n",
        "    injected = {key: globals()[key] for key in parameter_keys if key in globals()}\n",
        "    if injected:\n",
        "        return injected\n",
        "    try:\n",
        "        raw = dict(params)\n",
        "        if raw:\n",
        "            return raw\n",
        "    except Exception:\n",
        "        pass\n",
        "    qmd_path = PROJECT_ROOT / \"computedraft.qmd\"\n",
        "    if not qmd_path.exists():\n",
        "        raw = {}\n",
        "        return raw\n",
        "    try:\n",
        "        text = qmd_path.read_text(encoding=\"utf-8\")\n",
        "        if not text.startswith(\"---\"):\n",
        "            return {}\n",
        "        end_idx = text.find(\"\\n---\", 4)\n",
        "        if end_idx < 0:\n",
        "            return {}\n",
        "        frontmatter = yaml.safe_load(text[4:end_idx]) or {}\n",
        "        params_block = frontmatter.get(\"params\", {})\n",
        "        return dict(params_block) if isinstance(params_block, dict) else {}\n",
        "    except Exception:\n",
        "        return {}\n",
        "\n",
        "\n",
        "def get_rl_defaults(rl: int) -> dict[str, object]:\n",
        "    rl_int = int(rl)\n",
        "    shared = {\n",
        "        \"cache_mode\": \"prefer_cache\",\n",
        "        \"cache_version\": \"v1\",\n",
        "        \"artifact_tag\": \"default\",\n",
        "        \"model_family\": \"ar1\",\n",
        "        \"pooling_mode\": \"unit_specific\",\n",
        "        \"covariate_mode\": \"none\",\n",
        "        \"mask_regime\": \"random_hours\",\n",
        "        \"missing_fraction\": 0.20,\n",
        "        \"mask_seed\": 531,\n",
        "        \"n_mask_replicates\": 1,\n",
        "        \"fit_scope\": \"both\",\n",
        "        \"section_scope\": \"all\",\n",
        "        \"global_seed\": 531,\n",
        "        \"analysis_start_utc_iso\": \"2024-07-01T00:00:00+00:00\",\n",
        "        \"analysis_end_utc_iso\": \"2024-09-30T23:00:00+00:00\",\n",
        "        \"assumed_local_timezone\": \"America/New_York\",\n",
        "    }\n",
        "    presets = {\n",
        "        0: {\n",
        "            **shared,\n",
        "            \"RL\": 0,\n",
        "            \"device\": \"cpu\",\n",
        "            \"participant_set\": \"small_set\",\n",
        "            \"model_set\": \"smoke\",\n",
        "            \"panel_chunk_size\": 1,\n",
        "            \"stage1_starts\": 1,\n",
        "            \"stage2_starts\": 1,\n",
        "            \"stage1_keep_top\": 1,\n",
        "            \"stage2_keep_top\": 1,\n",
        "            \"stage1_particles\": 20,\n",
        "            \"stage2_particles\": 20,\n",
        "            \"stage1_if2_iterations\": 1,\n",
        "            \"stage2_if2_iterations\": 1,\n",
        "            \"stage1_cooling_fraction\": 0.50,\n",
        "            \"stage2_cooling_fraction\": 0.50,\n",
        "            \"stage1_rw_sd_scale\": 0.02,\n",
        "            \"stage2_rw_sd_scale\": 0.02,\n",
        "            \"cooling_fraction\": 0.50,\n",
        "            \"rw_sd_scale\": 0.02,\n",
        "            \"stage1_eval_particles\": 20,\n",
        "            \"stage2_eval_particles\": 20,\n",
        "            \"stage1_eval_reps\": 1,\n",
        "            \"stage2_eval_reps\": 1,\n",
        "            \"stage1_fresh_random_starts\": 0,\n",
        "            \"stage2_fresh_random_starts\": 0,\n",
        "            \"stage1_jittered_restarts\": 0,\n",
        "            \"stage2_jittered_restarts\": 0,\n",
        "        },\n",
        "        1: {\n",
        "            **shared,\n",
        "            \"RL\": 1,\n",
        "            \"device\": \"gpu\",\n",
        "            \"participant_set\": \"full_set\",\n",
        "            \"model_set\": \"smoke\",\n",
        "            \"pooling_mode\": \"all\",\n",
        "            \"panel_chunk_size\": 78,\n",
        "            \"stage1_starts\": 10,\n",
        "            \"stage2_starts\": 5,\n",
        "            \"stage1_keep_top\": 2,\n",
        "            \"stage2_keep_top\": 1,\n",
        "            \"stage1_particles\": 200,\n",
        "            \"stage2_particles\": 200,\n",
        "            \"stage1_if2_iterations\": 5,\n",
        "            \"stage2_if2_iterations\": 5,\n",
        "            \"stage1_cooling_fraction\": 0.90,\n",
        "            \"stage2_cooling_fraction\": 0.90,\n",
        "            \"stage1_rw_sd_scale\": 0.02,\n",
        "            \"stage2_rw_sd_scale\": 0.015,\n",
        "            \"cooling_fraction\": 0.90,\n",
        "            \"rw_sd_scale\": 0.02,\n",
        "            \"stage1_eval_particles\": 300,\n",
        "            \"stage2_eval_particles\": 200,\n",
        "            \"stage1_eval_reps\": 5,\n",
        "            \"stage2_eval_reps\": 5,\n",
        "            \"stage1_fresh_random_starts\": 0,\n",
        "            \"stage2_fresh_random_starts\": 0,\n",
        "            \"stage1_jittered_restarts\": 0,\n",
        "            \"stage2_jittered_restarts\": 1,\n",
        "        },\n",
        "        2: {\n",
        "            **shared,\n",
        "            \"RL\": 2,\n",
        "            \"device\": \"gpu\",\n",
        "            \"participant_set\": \"full_set\",\n",
        "            \"model_set\": \"single\",\n",
        "            \"pooling_mode\": \"all\",\n",
        "            \"fit_scope\": \"masked_only\",\n",
        "            \"panel_chunk_size\": 78,\n",
        "            \"stage1_starts\": 32,\n",
        "            \"stage2_starts\": 16,\n",
        "            \"stage1_keep_top\": 16,\n",
        "            \"stage2_keep_top\": 1,\n",
        "            \"stage1_particles\": 1024,\n",
        "            \"stage2_particles\": 512,\n",
        "            \"stage1_if2_iterations\": 16,\n",
        "            \"stage2_if2_iterations\": 16,\n",
        "            \"stage1_cooling_fraction\": 0.60,\n",
        "            \"stage2_cooling_fraction\": 0.60,\n",
        "            \"stage1_rw_sd_scale\": 0.02,\n",
        "            \"stage2_rw_sd_scale\": 0.02,\n",
        "            \"cooling_fraction\": 0.60,\n",
        "            \"rw_sd_scale\": 0.02,\n",
        "            \"stage1_eval_particles\": 256,\n",
        "            \"stage2_eval_particles\": 256,\n",
        "            \"stage1_eval_reps\": 16,\n",
        "            \"stage2_eval_reps\": 8,\n",
        "            \"stage1_fresh_random_starts\": 0,\n",
        "            \"stage2_fresh_random_starts\": 0,\n",
        "            \"stage1_jittered_restarts\": 0,\n",
        "            \"stage2_jittered_restarts\": 0,\n",
        "            \"phi_window_low\": -0.3,\n",
        "            \"phi_window_high\": 1.0,\n",
        "            \"sigma_window_low\": 0.01,\n",
        "            \"sigma_window_high\": 1.8,\n",
        "            \"k_fitbit_window_low\": 0.75,\n",
        "            \"k_fitbit_window_high\": 12.0,\n",
        "            \"log_k_fitbit_window_low\": -0.2876820724517809,\n",
        "            \"log_k_fitbit_window_high\": 2.4849066497880004,\n",
        "            \"mu_log_k_fitbit_window_low\": 0.2,\n",
        "            \"mu_log_k_fitbit_window_high\": 2.0,\n",
        "            \"log_tau_log_k_fitbit_window_low\": -1.7,\n",
        "            \"log_tau_log_k_fitbit_window_high\": 1.0,\n",
        "        },\n",
        "    }\n",
        "    if rl_int not in presets:\n",
        "        raise ValueError(f\"Unsupported RL preset: {rl}\")\n",
        "    return presets[rl_int]\n",
        "\n",
        "\n",
        "def resolve_config(raw_params: dict[str, object]) -> dict[str, object]:\n",
        "    defaults = get_rl_defaults(int(raw_params.get(\"RL\", 0)))\n",
        "    resolved = dict(defaults)\n",
        "    for key, value in raw_params.items():\n",
        "        if value is None:\n",
        "            continue\n",
        "        if isinstance(value, str) and value == \"\":\n",
        "            continue\n",
        "        resolved[key] = value\n",
        "    resolved[\"RL\"] = int(resolved[\"RL\"])\n",
        "    resolved[\"missing_fraction\"] = float(resolved[\"missing_fraction\"])\n",
        "    resolved[\"mask_seed\"] = int(resolved[\"mask_seed\"])\n",
        "    resolved[\"n_mask_replicates\"] = int(resolved[\"n_mask_replicates\"])\n",
        "    resolved[\"global_seed\"] = int(resolved[\"global_seed\"])\n",
        "    if resolved.get(\"panel_chunk_size\") is not None:\n",
        "        resolved[\"panel_chunk_size\"] = int(resolved[\"panel_chunk_size\"])\n",
        "    for name in (\n",
        "        \"stage1_starts\",\n",
        "        \"stage2_starts\",\n",
        "        \"stage1_keep_top\",\n",
        "        \"stage2_keep_top\",\n",
        "        \"stage1_particles\",\n",
        "        \"stage2_particles\",\n",
        "        \"stage1_if2_iterations\",\n",
        "        \"stage2_if2_iterations\",\n",
        "        \"stage1_eval_particles\",\n",
        "        \"stage2_eval_particles\",\n",
        "        \"stage1_eval_reps\",\n",
        "        \"stage2_eval_reps\",\n",
        "        \"stage1_fresh_random_starts\",\n",
        "        \"stage2_fresh_random_starts\",\n",
        "        \"stage1_jittered_restarts\",\n",
        "        \"stage2_jittered_restarts\",\n",
        "    ):\n",
        "        if resolved.get(name) is not None:\n",
        "            resolved[name] = int(resolved[name])\n",
        "    for name in (\n",
        "        \"cooling_fraction\",\n",
        "        \"rw_sd_scale\",\n",
        "        \"stage1_cooling_fraction\",\n",
        "        \"stage2_cooling_fraction\",\n",
        "        \"stage1_rw_sd_scale\",\n",
        "        \"stage2_rw_sd_scale\",\n",
        "        \"phi_window_low\",\n",
        "        \"phi_window_high\",\n",
        "        \"phi1_window_low\",\n",
        "        \"phi1_window_high\",\n",
        "        \"phi2_window_low\",\n",
        "        \"phi2_window_high\",\n",
        "        \"phi24_window_low\",\n",
        "        \"phi24_window_high\",\n",
        "        \"sigma_window_low\",\n",
        "        \"sigma_window_high\",\n",
        "        \"k_fitbit_window_low\",\n",
        "        \"k_fitbit_window_high\",\n",
        "        \"log_k_fitbit_window_low\",\n",
        "        \"log_k_fitbit_window_high\",\n",
        "        \"mu_log_k_fitbit_window_low\",\n",
        "        \"mu_log_k_fitbit_window_high\",\n",
        "        \"log_tau_log_k_fitbit_window_low\",\n",
        "        \"log_tau_log_k_fitbit_window_high\",\n",
        "        \"eta_wear_lag1_window_low\",\n",
        "        \"eta_wear_lag1_window_high\",\n",
        "        \"wear_phi_window_low\",\n",
        "        \"wear_phi_window_high\",\n",
        "        \"wear_sigma_window_low\",\n",
        "        \"wear_sigma_window_high\",\n",
        "    ):\n",
        "        if resolved.get(name) is not None:\n",
        "            resolved[name] = float(resolved[name])\n",
        "    if resolved.get(\"stage1_cooling_fraction\") is None:\n",
        "        resolved[\"stage1_cooling_fraction\"] = float(resolved[\"cooling_fraction\"])\n",
        "    if resolved.get(\"stage2_cooling_fraction\") is None:\n",
        "        resolved[\"stage2_cooling_fraction\"] = float(resolved[\"cooling_fraction\"])\n",
        "    if resolved.get(\"stage1_rw_sd_scale\") is None:\n",
        "        resolved[\"stage1_rw_sd_scale\"] = float(resolved[\"rw_sd_scale\"])\n",
        "    if resolved.get(\"stage2_rw_sd_scale\") is None:\n",
        "        resolved[\"stage2_rw_sd_scale\"] = float(resolved[\"rw_sd_scale\"])\n",
        "    for name in (\n",
        "        \"stage1_fresh_random_starts\",\n",
        "        \"stage2_fresh_random_starts\",\n",
        "        \"stage1_jittered_restarts\",\n",
        "        \"stage2_jittered_restarts\",\n",
        "    ):\n",
        "        if resolved.get(name) is None:\n",
        "            resolved[name] = 0\n",
        "    return resolved\n",
        "\n",
        "\n",
        "RAW_PARAMS = _raw_params()\n",
        "RESOLVED_CONFIG = resolve_config(RAW_PARAMS)\n",
        "\n",
        "MODEL_SET_REGISTRY = {\n",
        "    \"single\": [],\n",
        "    \"smoke\": [\"ar1\", \"arma_aic\"],\n",
        "    \"core\": [\n",
        "        \"ar1\",\n",
        "        \"ar2\",\n",
        "        \"wear_observation\",\n",
        "        \"wear_latent\",\n",
        "        \"ar2_wear_observation\",\n",
        "        \"ar2_wear_latent\",\n",
        "        \"arma_aic\",\n",
        "    ],\n",
        "    \"all\": [\n",
        "        \"ar1\",\n",
        "        \"ar2\",\n",
        "        \"wear_observation\",\n",
        "        \"wear_latent\",\n",
        "        \"ar2_wear_observation\",\n",
        "        \"ar2_wear_latent\",\n",
        "        \"arma_aic\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "POOLING_MODE_OPTIONS = [\n",
        "    \"unit_specific\",\n",
        "    \"global_shared_k\",\n",
        "    \"partial_pooled_k\",\n",
        "]\n",
        "\n",
        "GLOBAL_START_BOX_DEFAULTS = {\n",
        "    \"phi\": (-0.95, 0.95),\n",
        "    \"phi1\": (-1.25, 1.25),\n",
        "    \"phi2\": (-0.99, 0.99),\n",
        "    \"phi24\": (-0.99, 0.99),\n",
        "    \"sigma\": (0.05, 2.00),\n",
        "    \"k_fitbit\": (0.01, 10.0),\n",
        "    \"log_k_fitbit\": (-3, 2),\n",
        "    \"mu_log_k_fitbit\": (-3, 2),\n",
        "    \"log_tau_log_k_fitbit\": (-2, 1),\n",
        "    \"eta_wear_lag1\": (-4.0, 4.0),\n",
        "    \"wear_phi\": (-0.99, 0.99),\n",
        "    \"wear_sigma\": (0.05, 2.0),\n",
        "}\n",
        "\n",
        "WINDOW_PARAM_FIELDS = {\n",
        "    \"phi\": (\"phi_window_low\", \"phi_window_high\"),\n",
        "    \"phi1\": (\"phi1_window_low\", \"phi1_window_high\"),\n",
        "    \"phi2\": (\"phi2_window_low\", \"phi2_window_high\"),\n",
        "    \"phi24\": (\"phi24_window_low\", \"phi24_window_high\"),\n",
        "    \"sigma\": (\"sigma_window_low\", \"sigma_window_high\"),\n",
        "    \"k_fitbit\": (\"k_fitbit_window_low\", \"k_fitbit_window_high\"),\n",
        "    \"log_k_fitbit\": (\"log_k_fitbit_window_low\", \"log_k_fitbit_window_high\"),\n",
        "    \"mu_log_k_fitbit\": (\"mu_log_k_fitbit_window_low\", \"mu_log_k_fitbit_window_high\"),\n",
        "    \"log_tau_log_k_fitbit\": (\"log_tau_log_k_fitbit_window_low\", \"log_tau_log_k_fitbit_window_high\"),\n",
        "    \"eta_wear_lag1\": (\"eta_wear_lag1_window_low\", \"eta_wear_lag1_window_high\"),\n",
        "    \"wear_phi\": (\"wear_phi_window_low\", \"wear_phi_window_high\"),\n",
        "    \"wear_sigma\": (\"wear_sigma_window_low\", \"wear_sigma_window_high\"),\n",
        "}\n",
        "\n",
        "\n",
        "def _parameter_window_overrides(config: dict[str, object]) -> dict[str, tuple[float, float]]:\n",
        "    overrides: dict[str, tuple[float, float]] = {}\n",
        "    for param_name, (low_key, high_key) in WINDOW_PARAM_FIELDS.items():\n",
        "        low_value = config.get(low_key)\n",
        "        high_value = config.get(high_key)\n",
        "        if low_value is None and high_value is None:\n",
        "            continue\n",
        "        default_low, default_high = GLOBAL_START_BOX_DEFAULTS[param_name]\n",
        "        resolved_low = float(default_low if low_value is None else low_value)\n",
        "        resolved_high = float(default_high if high_value is None else high_value)\n",
        "        if resolved_low >= resolved_high:\n",
        "            raise ValueError(f\"Search window for {param_name} must satisfy low < high.\")\n",
        "        overrides[param_name] = (resolved_low, resolved_high)\n",
        "    return overrides\n",
        "\n",
        "\n",
        "def _active_model_families(config: dict[str, object]) -> list[str]:\n",
        "    model_set_name = str(config[\"model_set\"])\n",
        "    if model_set_name not in MODEL_SET_REGISTRY:\n",
        "        raise ValueError(f\"Unknown model_set: {model_set_name}\")\n",
        "    families = list(MODEL_SET_REGISTRY[model_set_name])\n",
        "    requested_family = str(config[\"model_family\"])\n",
        "    if requested_family not in families:\n",
        "        families.append(requested_family)\n",
        "    return families\n",
        "\n",
        "\n",
        "def _active_pooling_modes(config: dict[str, object]) -> list[str]:\n",
        "    raw_value = config.get(\"pooling_mode\", \"unit_specific\")\n",
        "    if isinstance(raw_value, str):\n",
        "        stripped = raw_value.strip()\n",
        "        if stripped.lower() == \"all\":\n",
        "            requested = list(POOLING_MODE_OPTIONS)\n",
        "        elif \",\" in stripped:\n",
        "            requested = [part.strip() for part in stripped.split(\",\") if part.strip()]\n",
        "        else:\n",
        "            requested = [stripped]\n",
        "    elif isinstance(raw_value, (list, tuple, set)):\n",
        "        requested = [str(item).strip() for item in raw_value if str(item).strip()]\n",
        "    else:\n",
        "        requested = [str(raw_value).strip()]\n",
        "\n",
        "    active_modes: list[str] = []\n",
        "    for mode in requested:\n",
        "        if mode not in POOLING_MODE_OPTIONS:\n",
        "            raise ValueError(f\"Unknown pooling_mode: {mode}\")\n",
        "        if mode not in active_modes:\n",
        "            active_modes.append(mode)\n",
        "    if not active_modes:\n",
        "        raise ValueError(\"At least one pooling mode must be selected.\")\n",
        "    return active_modes\n",
        "\n",
        "\n",
        "RESOLVED_CONFIG[\"active_model_families\"] = _active_model_families(RESOLVED_CONFIG)\n",
        "RESOLVED_CONFIG[\"active_pooling_modes\"] = _active_pooling_modes(RESOLVED_CONFIG)\n",
        "PARAMETER_WINDOW_OVERRIDES = _parameter_window_overrides(RESOLVED_CONFIG)\n",
        "RESOLVED_CONFIG[\"search_windows\"] = {\n",
        "    **GLOBAL_START_BOX_DEFAULTS,\n",
        "    **PARAMETER_WINDOW_OVERRIDES,\n",
        "}\n",
        "\n",
        "CACHE_ROOT = PROJECT_ROOT / \"cache\" / \"computedraft\" / str(RESOLVED_CONFIG[\"cache_version\"]) / str(RESOLVED_CONFIG[\"artifact_tag\"])\n",
        "CACHE_PATHS = {\n",
        "    \"root\": CACHE_ROOT,\n",
        "    \"base\": CACHE_ROOT / \"base\",\n",
        "    \"masks\": CACHE_ROOT / \"masks\",\n",
        "    \"fits_unmasked\": CACHE_ROOT / \"fits\" / \"unmasked\",\n",
        "    \"fits_masked\": CACHE_ROOT / \"fits\" / \"masked\",\n",
        "    \"benchmarks\": CACHE_ROOT / \"benchmarks\",\n",
        "    \"derived\": CACHE_ROOT / \"derived\",\n",
        "    \"manifests\": CACHE_ROOT / \"manifests\",\n",
        "    \"logs\": CACHE_ROOT / \"logs\",\n",
        "}\n",
        "for path in CACHE_PATHS.values():\n",
        "    path.mkdir(parents=True, exist_ok=True)\n",
        "HELPERS_ROOT.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "requested_device = str(RESOLVED_CONFIG[\"device\"]).strip().lower()\n",
        "if requested_device not in {\"cpu\", \"gpu\"}:\n",
        "    raise ValueError(f\"device must be 'cpu' or 'gpu', got {RESOLVED_CONFIG['device']!r}\")\n",
        "# JAX wants concrete backend names here. In our WSL + NVIDIA setup, asking for\n",
        "# GPU should force CUDA rather than letting a stray ROCm probe interfere.\n",
        "os.environ[\"JAX_PLATFORMS\"] = \"cuda\" if requested_device == \"gpu\" else \"cpu\"\n",
        "\n",
        "SEARCH_STAGE_SETTINGS = [\n",
        "    {\n",
        "        \"name\": \"Stage 1\",\n",
        "        \"n_starts\": int(RESOLVED_CONFIG[\"stage1_starts\"]),\n",
        "        \"keep_top\": int(RESOLVED_CONFIG[\"stage1_keep_top\"]),\n",
        "        \"particles\": int(RESOLVED_CONFIG[\"stage1_particles\"]),\n",
        "        \"mif_iterations\": int(RESOLVED_CONFIG[\"stage1_if2_iterations\"]),\n",
        "        \"cooling_fraction\": float(RESOLVED_CONFIG[\"stage1_cooling_fraction\"]),\n",
        "        \"rw_sd_scale\": float(RESOLVED_CONFIG[\"stage1_rw_sd_scale\"]),\n",
        "        \"evaluation_particles\": int(RESOLVED_CONFIG[\"stage1_eval_particles\"]),\n",
        "        \"evaluation_pfilter_reps\": int(RESOLVED_CONFIG[\"stage1_eval_reps\"]),\n",
        "        \"n_fresh_random_starts\": int(RESOLVED_CONFIG[\"stage1_fresh_random_starts\"]),\n",
        "        \"n_jittered_restarts\": int(RESOLVED_CONFIG[\"stage1_jittered_restarts\"]),\n",
        "    },\n",
        "    {\n",
        "        \"name\": \"Stage 2\",\n",
        "        \"n_starts\": int(RESOLVED_CONFIG[\"stage2_starts\"]),\n",
        "        \"keep_top\": int(RESOLVED_CONFIG[\"stage2_keep_top\"]),\n",
        "        \"particles\": int(RESOLVED_CONFIG[\"stage2_particles\"]),\n",
        "        \"mif_iterations\": int(RESOLVED_CONFIG[\"stage2_if2_iterations\"]),\n",
        "        \"cooling_fraction\": float(RESOLVED_CONFIG[\"stage2_cooling_fraction\"]),\n",
        "        \"rw_sd_scale\": float(RESOLVED_CONFIG[\"stage2_rw_sd_scale\"]),\n",
        "        \"evaluation_particles\": int(RESOLVED_CONFIG[\"stage2_eval_particles\"]),\n",
        "        \"evaluation_pfilter_reps\": int(RESOLVED_CONFIG[\"stage2_eval_reps\"]),\n",
        "        \"n_fresh_random_starts\": int(RESOLVED_CONFIG[\"stage2_fresh_random_starts\"]),\n",
        "        \"n_jittered_restarts\": int(RESOLVED_CONFIG[\"stage2_jittered_restarts\"]),\n",
        "    },\n",
        "]\n",
        "\n",
        "RESOLVED_CONFIG[\"config_hash\"] = hashlib.sha256(\n",
        "    json.dumps(RESOLVED_CONFIG, sort_keys=True, default=str).encode(\"utf-8\")\n",
        ").hexdigest()[:16]\n",
        "AGGREGATE_PROGRESS_LOG_PATH = CACHE_PATHS[\"logs\"] / f\"aggregate_progress_{RESOLVED_CONFIG['config_hash']}.jsonl\"\n",
        "AGGREGATE_PROGRESS_MANIFEST_PATH = CACHE_PATHS[\"logs\"] / f\"aggregate_progress_manifest_{RESOLVED_CONFIG['config_hash']}.csv\"\n",
        "\n",
        "resolved_config_table = pd.DataFrame(\n",
        "    [{\"setting\": key, \"value\": json.dumps(value, default=str) if isinstance(value, (dict, list, tuple)) else value} for key, value in RESOLVED_CONFIG.items()]\n",
        ")\n",
        "resolved_config_table.to_json(CACHE_PATHS[\"logs\"] / f\"resolved_config_{RESOLVED_CONFIG['config_hash']}.json\", orient=\"records\", indent=2)"
      ],
      "id": "compute-interface",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Introduction\n",
        "\n",
        "## Background Information and Project Motivation\n",
        "\n",
        "<!-- \n",
        "Intern Health Study (IHS) 2024 -> data on ~1000 new doctors\n",
        "\n",
        "three domains (mood, sleep, and activity) but we are only focusing on activity\n",
        "\n",
        "three wearable devies (garmin, apple, fitbit) -> disconnect in devices\n",
        "\n",
        "at 3 pm, individuals have a 50% change of receiving a message (decided by an agent) \n",
        "\n",
        "goal: maximize step count which is the reward (I think?)\n",
        "-->\n",
        "\n",
        "The Intern Health Study (IHS) 2024 contains data on approximately 1,000 new doctors. @internhealthstudy The study collects information across three domains: mood, sleep, and physical activity. In this project, we focus only on physical activity which is measured using step count.\n",
        "\n",
        "At 3:00 p.m. each day, an agent decides whether a participant receives a message, with a 50% probability of sending a message and a 50% probability of not sending one. This randomized setup allows researchers to study whether these messages influence participants' behavior. In this context, the objective is to increase physical activity, so step count serves as the reward outcome of interest.\n",
        "\n",
        "<!-- \n",
        "RoME is a robust contextual bandit method for health apps that decides when to send notifications and how to personalize interventions based on the user’s current situation. @RoME\n",
        "\n",
        "Oralytics, a mHealth intervention system, uses an online RL algorithm to determine optimal times for delivering interventions to promote oral self-care behaviors. @Oralytics\n",
        "\n",
        "Missing data may result in distortions that alter algorithm behavior. Robust strategies are needed to handle delayed and missing data because the algorithm needs to continue functioning despite these challenges and ensure reproducibility. @DigitalHealth\n",
        "-->\n",
        "\n",
        "Reinforcement learning and contextual bandit methods are becoming increasingly important in healthcare because they enable personalized interventions. In digital health, these methods can be used to decide when and how to deliver prompts that encourage healthier behaviors, such as increasing physical activity or improving medication adherence. Contextual bandits are especially useful because they incorporate patient characteristics when selecting an action. For example, RoME is a robust contextual bandit method for mobile health applications that determines when to send notifications and how to personalize interventions based on a user’s current situation. @RoME Similarly, Oralytics is a mobile health intervention system that uses an online reinforcement learning algorithm to determine optimal times to deliver interventions that promote oral self-care behaviors. @Oralytics\n",
        "\n",
        "This project is motivated by the growing need to apply these methods in realistic settings where data is often incomplete. In our dataset, missingness occurs when users do not wear their devices which leads to gaps in the recorded activity data. Missing data can distort the information available to the algorithm and may ultimately affect its behavior and performance. As a result, robust strategies for handling delayed and missing data are essential so that the algorithm can continue to function reliably and produce reproducible results. @DigitalHealth\n",
        "\n",
        "## Past Project Context\n",
        "\n",
        "<!-- \n",
        "1. [Heart Rate Variability](https://ionides.github.io/531w25/final_project/project10/blinded.pdf)\n",
        "\n",
        "LG-POMP model; Apple measurements only\n",
        "Peer review comments - more diagnostic plots, like looking at likelihood anomalies\n",
        "No description of time zone handling\n",
        "-->\n",
        "\n",
        "Most past projects centered on infectious disease or financial topics. There was one project that also looked at measurements from wearable devices @HeartRate. That project focused on the instantaneous effect of environmental noise on heart rate variability (HRV), while ours is primarily about step count in the next 24 hours following a motivating message.\n",
        "\n",
        "Both projects face the same issue of missing data. The HRV project pooled all participants together into a population-level daily summary, taking the median measurement of each day, while we initally designed POMP models for individual participants and then **[describe our pooling method]**. We investigate the effects of missingness on model performance by masking a percentage of the data, fitting a smoother, and calculating the RMSE. [**Haven't done yet** We also include other measurements from the wearable device as covariates in our model, which the HRV project did not do.] After reading past peer reviews, we made sure to add more diagnostic plots, including those describing likelihood anomalies and effective sample size.\n",
        "\n",
        "## Research Question\n",
        "\n",
        "When a participant does not wear the watch, no step count data are collected during that period. On days when the watch is worn for only a short time, or not at all, a reward cannot be constructed, so that day provides no training information for the model. The goal of this project is to build personalized POMP models for each doctor and use smoothing to estimate the missing rewards.\n",
        "\n",
        "# Data Overview\n",
        "\n",
        "## Data Description and Preprocessing\n",
        "\n",
        "Participants wear devices from Garmin, Fitbit, and Apple, and some individuals may use more than one device. Since these devices differ in how they record and store data, the dataset contains some inconsistencies across devices. For example, Fitbit records data in local time, whereas Apple and Garmin use a global time zone. Additionally, the devices may also differ because of measurement noise.\n",
        "\n",
        "## Multiple Device Analysis\n",
        "\n",
        "For this project, we focused only on users who had Fitbit data for several reasons. Since not many users had Garmin devices, it would be difficult to train the model with such limited data. Of the approximately 1,000 doctors in the data, only 88 used Garmin. Apple HealthKit acts as a central repository for health and fitness data which combines information from both phones and watches. In other words, different apps are allowed to sync and aggregate data. For example, HealthKit can integrate with other wearables such as Garmin, so the step data may not even originate from an Apple Watch. It is too difficult to disentangle the biases associated with this device. A significant portion of people use multiple devices as can be seen in the table below.\n",
        "\n",
        "\n",
        "\n",
        "<!--\n",
        "| Apple | Fitbit | Garmin | Apple + Fitbit | Fitbit + Garmin | Apple + Garmin | All Three | Total\n",
        "|---|---|---|\n",
        "| 557 | 82 | C |\n",
        ":  {#tbl-letters}\n",
        "-->\n",
        "\n",
        "(PRUNE FitbitHourly.csv to only July 1 to September 30, readjust back to local time)\n",
        "\n",
        "The FitbitHourly.csv dataset contains wearable data from July 1, 2024 to September 30, 2024 for 299 participants. We analyze the 78 participants who have Fitbit steps data for at least half of their hourly rows. \n",
        "\n",
        "Notes:\n",
        "* sample statistics like mean steps, std, mean steps per hourly non-missing bucket, missingness, maybe box plot for missingness (min, max, quartiles)."
      ],
      "id": "95d9395c"
    },
