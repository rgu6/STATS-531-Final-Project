      "source": [
        "The chart below is a scatterplot of the mean and standard deviation of hourly steps for each user after filtering to hours with non-missing data. The means are quite a bit larger than would be expected under an iid Poisson observation model, which motivates the use of a latent stochastic process together with a measurement model that allows extra dispersion."
      ],
      "id": "800b27fa"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "#| label: eda-mean-vs-sd\n",
        "\n",
        "non_missing = prune_df.loc[prune_df[\"fitbitStepsMissing\"] == 0].copy()\n",
        "non_missing[\"fitbitSteps\"] = pd.to_numeric(non_missing[\"fitbitSteps\"], errors=\"coerce\")\n",
        "non_missing = non_missing.dropna(subset=[\"fitbitSteps\"])\n",
        "\n",
        "stats = non_missing.groupby(\"PARTICIPANTIDENTIFIER\")[\"fitbitSteps\"].agg(\n",
        "    [\"mean\", \"std\"]\n",
        ").reset_index()\n",
        "\n",
        "plt.figure(figsize=(6.5, 4.5))\n",
        "plt.scatter(stats[\"mean\"], stats[\"std\"], alpha=0.8)\n",
        "plt.xlabel(\"Mean Fitbit steps\")\n",
        "plt.ylabel(\"Standard deviation of Fitbit steps\")\n",
        "plt.title(\"Mean versus variability in non-missing hourly Fitbit steps\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
