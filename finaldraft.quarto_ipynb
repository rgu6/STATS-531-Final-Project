        "            \"stage1_keep_top\": 16,\n",
        "            \"stage2_keep_top\": 1,\n",
        "            \"stage1_particles\": 1024,\n",
        "            \"stage2_particles\": 512,\n",
        "            \"stage1_if2_iterations\": 16,\n",
        "            \"stage2_if2_iterations\": 16,\n",
        "            \"stage1_cooling_fraction\": 0.60,\n",
        "            \"stage2_cooling_fraction\": 0.60,\n",
