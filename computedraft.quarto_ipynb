        "#| echo: false\n",
        "#| label: missingness-histogram\n",
        "# plot histogram of percent of hours with a step count missing for each participant for fitbit and apple\n",
        "# add same y-axis limits for both plots for easier comparison\n",
        "\n",
        "sns.histplot(fitbit_steps_missing_percent, bins=20, color='steelblue',\n",
        "                edgecolor='black')\n",
        "plt.xlabel('Percent of hours with a step count missing (Fitbit)')\n",
        "plt.ylabel('Number of participants')\n",
