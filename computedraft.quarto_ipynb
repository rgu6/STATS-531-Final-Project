    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| warning: false\n",
        "#| echo: false\n",
        "#| label: filtered-reward-plot\n",
        "\n",
        "# Plot the filtered 24-hour reward reconstruction after the local 3pm decision\n",
        "# time. By default this uses the best fit from the global two-stage search.\n",
        "def select_plot_result(plot_source: str) -> tuple[StepPompRunResult, str]:\n",
        "    normalized_source = str(plot_source).strip().lower()\n",
        "    if normalized_source == \"local\":\n",
        "        return local_step_pomp_result, \"local fit\"\n",
        "    return global_best_run, \"global-best fit\"\n",
        "\n",
        "\n",
        "plot_result, plot_label = select_plot_result(reward_plot_fit_source)\n",
        "\n",
        "reward_plot = plot_result.reward_frame.copy()\n",
        "reward_plot = reward_plot.loc[reward_plot[\"complete_window\"]].copy()\n",
        "reward_plot[\"decision_date\"] = pd.to_datetime(\n",
        "    reward_plot[\"decision_local_time\"],\n",
        "    errors=\"coerce\",\n",
        ").dt.tz_localize(None)\n",
        "\n",
        "plt.style.use(\"seaborn-v0_8-whitegrid\")\n",
        "fig, ax = plt.subplots(figsize=(reward_plot_fig_width, reward_plot_fig_height))\n",
        "\n",
        "ax.bar(\n",
        "    reward_plot[\"decision_date\"],\n",
        "    reward_plot[\"latent_reward_24h\"],\n",
        "    color=\"#d69e2e\",\n",
        "    alpha=0.75,\n",
        "    width=0.8,\n",
        "    label=\"Filtered latent reward\",\n",
        ")\n",
        "ax.plot(\n",
        "    reward_plot[\"decision_date\"],\n",
        "    reward_plot[\"fitbit_observed_reward_24h\"],\n",
        "    color=\"#2b6cb0\",\n",
        "    linewidth=1.8,\n",
        "    marker=\"o\",\n",
        "    markersize=3,\n",
        "    label=\"Observed Fitbit subtotal\",\n",
        ")\n",
        "\n",
        "ax.set_title(\n",
        "    f\"Reconstructed 24-hour filtered reward for {participant_id} ({plot_label})\",\n",
        "    fontsize=reward_plot_title_fontsize,\n",
        ")\n",
        "ax.set_xlabel(\"Decision date\", fontsize=reward_plot_axis_label_fontsize)\n",
        "ax.set_ylabel(\"24-hour step total\", fontsize=reward_plot_axis_label_fontsize)\n",
        "ax.legend(frameon=False, ncol=2, fontsize=reward_plot_legend_fontsize)\n",
        "ax.tick_params(axis=\"both\", labelsize=reward_plot_tick_fontsize)\n",
        "plt.xticks(rotation=45, ha=\"right\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "filtered-reward-plot",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| warning: false\n",
        "#| echo: false\n",
        "#| label: residual-plot\n",
        "\n",
        "# Plot residual = filtered latent reward - observed Fitbit subtotal against the\n",
        "# number of missing Fitbit hours in the 24-hour reward window.\n",
        "plot_result, _ = select_plot_result(residual_plot_fit_source)\n",
        "residual_plot = plot_result.reward_frame.copy()\n",
        "residual_plot = residual_plot.loc[residual_plot[\"complete_window\"]].copy()\n",
        "residual_plot[\"missing_fitbit_hours\"] = (\n",
        "    24\n",
        "    - pd.to_numeric(\n",
        "        residual_plot[\"fitbit_observed_hours\"],\n",
        "        errors=\"coerce\",\n",
        "    ).fillna(0.0)\n",
        ").round().clip(lower=0, upper=24).astype(int)\n",
        "residual_plot[\"reward_residual\"] = (\n",
        "    pd.to_numeric(residual_plot[\"latent_reward_24h\"], errors=\"coerce\")\n",
        "    - pd.to_numeric(residual_plot[\"fitbit_observed_reward_24h\"], errors=\"coerce\")\n",
        ")\n",
        "\n",
        "plt.style.use(\"seaborn-v0_8-whitegrid\")\n",
        "fig, ax = plt.subplots(figsize=(residual_plot_fig_width, residual_plot_fig_height))\n",
        "\n",
        "ax.scatter(\n",
        "    residual_plot[\"missing_fitbit_hours\"],\n",
        "    residual_plot[\"reward_residual\"],\n",
        "    color=\"#d69e2e\",\n",
        "    edgecolor=\"#8c6d1f\",\n",
        "    alpha=0.8,\n",
        "    s=40,\n",
        ")\n",
        "ax.axhline(0.0, color=\"#4a5568\", linewidth=1.2, linestyle=\"--\")\n",
        "\n",
        "ax.set_title(f\"Filtered reward residual vs missingness for {participant_id}\")\n",
        "ax.set_xlabel(\"Missing Fitbit hours in 24-hour window\")\n",
        "ax.set_ylabel(\"Filtered reward - observed subtotal\")\n",
        "ax.set_xlim(-0.5, 24.5)\n",
        "ax.set_xticks(np.arange(0, 25, 1))\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "residual-plot",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Notice that the estimated latent reward always upper bounds the observed reward. This is because it's a sum of hourly buckets, for which many of the observations are missing. The second plot (maybe include a trend line?) shows that there's a linear trend in how much the estimated latent exceeds the observed. This is unsurprising; if the observed only sums 8 non-zero buckets, the latent sums 24 non-zero buckets, and might be approximately three times larger. This discrepancy is the point of using a latent model to begin-with, we expect that there are many steps the participant is taking that aren't being picked up. However, this introduces great challenges in benchmarking (elaborate on challenges?).\n",
        "\n",
        "Maybe do for three participants? Low medium high missingness.\n",
        "\n",
        "## Aggregate modeling\n",
        "\n",
        "The aggregate analysis uses the same CSV as the individual section, but runs a cache-first panel pipeline. The expensive work is staged once here, and the visible tables and plots below only read cached or derived artifacts."
      ],
      "id": "aabe6138"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "#| label: aggregate-imports\n",
        "\n",
        "from helpers.computedraft_pipeline import run_cache_first_pipeline\n",
        "from src.ihs_eda.step_pomp import (\n",
        "    build_heldout_subtotal_benchmark_frame,\n",
        "    build_masked_hourly_benchmark_frame,\n",
        ")"
      ],
      "id": "aggregate-imports",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "#| label: aggregate-progress-setup\n",
        "\n",
        "# AGGREGATE PROGRESS SETUP\n",
        "# Long aggregate runs write a live JSONL event log plus a task-status CSV under\n",
        "# the cache logs directory. Tail these in a second terminal while Quarto runs.\n",
        "\n",
        "aggregate_progress_log_path = AGGREGATE_PROGRESS_LOG_PATH\n",
        "aggregate_progress_manifest_path = AGGREGATE_PROGRESS_MANIFEST_PATH"
      ],
      "id": "aggregate-progress-setup",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "#| label: aggregate-compute\n",
        "\n",
        "# BIG COMPUTE CHUNK STARTS HERE\n",
        "# This is the only place in the report that is allowed to launch the aggregate\n",
        "# panel fits and masking benchmarks. All later chunks read the cached outputs.\n",
        "\n",
        "aggregate_config = dict(RESOLVED_CONFIG)\n",
        "aggregate_config[\"search_stage_settings\"] = SEARCH_STAGE_SETTINGS\n",
        "\n",
        "aggregate_result = run_cache_first_pipeline(\n",
        "    CSV_PATH,\n",
        "    resolved_config=aggregate_config,\n",
        "    cache_paths=CACHE_PATHS,\n",
        "    active_model_families=list(aggregate_config[\"active_model_families\"]),\n",
        "    active_pooling_modes=list(aggregate_config[\"active_pooling_modes\"]),\n",
        "    progress_callback=lambda message: print(message, flush=True),\n",
        ")"
      ],
      "id": "aggregate-compute",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "#| label: aggregate-derived\n",
        "\n",
        "# DERIVED ARTIFACTS CHUNK\n",
        "# The objects below are what the visible diagnostic chunks consume. They are all\n",
        "# already cached or derived from cached fits above.\n",
        "\n",
        "aggregate_base_artifact = aggregate_result.base_artifact\n",
        "aggregate_task_manifest = aggregate_result.task_manifest.copy()\n",
        "aggregate_derived_artifact = aggregate_result.derived_artifact\n",
        "aggregate_model_comparison = aggregate_derived_artifact.get(\"model_comparison\", pd.DataFrame()).copy()\n",
        "aggregate_benchmark_summary = aggregate_derived_artifact.get(\"benchmark_summary\", pd.DataFrame()).copy()\n",
        "aggregate_masked_fits = aggregate_derived_artifact.get(\"masked_fits\", {})\n",
        "aggregate_parameter_summary = aggregate_derived_artifact.get(\"parameter_summary\", pd.DataFrame()).copy()\n",
        "if aggregate_parameter_summary.empty and aggregate_masked_fits:\n",
        "    aggregate_parameter_summary = build_parameter_summary_from_masked_fits(aggregate_masked_fits)\n",
        "aggregate_timing_summary = aggregate_result.timing_summary.copy()\n",
        "aggregate_model_metric_summary, aggregate_correlation_summary, aggregate_participant_metric_frame = build_model_level_metric_tables(\n",
        "    aggregate_masked_fits,\n",
        "    aggregate_parameter_summary,\n",
        ")\n",
        "\n",
        "if (\n",
        "    not aggregate_model_comparison.empty\n",
        "    and not aggregate_parameter_summary.empty\n",
        "    and {\"model_family\", \"pooling_mode\", \"panel_unit_loglik\"}.issubset(aggregate_parameter_summary.columns)\n",
        "):\n",
        "    mean_loglik_by_model = (\n",
        "        aggregate_parameter_summary.groupby([\"model_family\", \"pooling_mode\"], as_index=False)\n",
        "        .agg(mean_panel_unit_loglik=(\"panel_unit_loglik\", lambda s: float(pd.to_numeric(s, errors=\"coerce\").mean())))\n",
        "    )\n",
        "    aggregate_model_comparison = aggregate_model_comparison.merge(\n",
        "        mean_loglik_by_model,\n",
        "        how=\"left\",\n",
        "        on=[\"model_family\", \"pooling_mode\"],\n",
        "    )\n",
        "\n",
        "aggregate_settings_table = pd.DataFrame(\n",
        "    [\n",
        "        {\n",
        "            \"RL\": aggregate_config[\"RL\"],\n",
        "            \"Device\": aggregate_config[\"device\"],\n",
        "            \"Participant set\": aggregate_config[\"participant_set\"],\n",
        "            \"Panel batch size\": aggregate_config[\"panel_chunk_size\"],\n",
        "            \"Model set\": aggregate_config[\"model_set\"],\n",
        "            \"Displayed model\": aggregate_config[\"model_family\"],\n",
        "            \"Pooling\": \", \".join(map(str, aggregate_config[\"active_pooling_modes\"])),\n",
        "            \"Covariates\": aggregate_config[\"covariate_mode\"],\n",
        "            \"Mask regime\": aggregate_config[\"mask_regime\"],\n",
        "            \"Missing fraction\": aggregate_config[\"missing_fraction\"],\n",
        "            \"Mask replicates\": aggregate_config[\"n_mask_replicates\"],\n",
        "            \"Stage 1 starts\": aggregate_config[\"stage1_starts\"],\n",
        "            \"Stage 2 starts\": aggregate_config[\"stage2_starts\"],\n",
        "            \"Stage 1 keep top\": aggregate_config[\"stage1_keep_top\"],\n",
        "            \"Stage 2 keep top\": aggregate_config[\"stage2_keep_top\"],\n",
        "            \"Stage 1 IF2 iterations\": aggregate_config[\"stage1_if2_iterations\"],\n",
        "            \"Stage 2 IF2 iterations\": aggregate_config[\"stage2_if2_iterations\"],\n",
        "            \"Stage 1 particles\": aggregate_config[\"stage1_particles\"],\n",
        "            \"Stage 2 particles\": aggregate_config[\"stage2_particles\"],\n",
        "            \"Stage 1 eval particles\": aggregate_config[\"stage1_eval_particles\"],\n",
        "            \"Stage 2 eval particles\": aggregate_config[\"stage2_eval_particles\"],\n",
        "            \"Stage 1 eval reps\": aggregate_config[\"stage1_eval_reps\"],\n",
        "            \"Stage 2 eval reps\": aggregate_config[\"stage2_eval_reps\"],\n",
        "            \"Stage 1 cooling\": aggregate_config[\"stage1_cooling_fraction\"],\n",
        "            \"Stage 2 cooling\": aggregate_config[\"stage2_cooling_fraction\"],\n",
        "            \"Stage 1 RW SD\": aggregate_config[\"stage1_rw_sd_scale\"],\n",
        "            \"Stage 2 RW SD\": aggregate_config[\"stage2_rw_sd_scale\"],\n",
        "            \"Stage 1 fresh starts\": aggregate_config[\"stage1_fresh_random_starts\"],\n",
        "            \"Stage 2 fresh starts\": aggregate_config[\"stage2_fresh_random_starts\"],\n",
        "            \"Stage 1 jittered\": aggregate_config[\"stage1_jittered_restarts\"],\n",
        "            \"Stage 2 jittered\": aggregate_config[\"stage2_jittered_restarts\"],\n",
        "        }\n",
        "    ]\n",
        ")"
      ],
      "id": "aggregate-derived",
      "execution_count": null,
      "outputs": []
    },
    {
