        "            \"mu_log_k_fitbit_window_low\": 0.2,\n",
        "            \"mu_log_k_fitbit_window_high\": 2.0,\n",
        "            \"log_tau_log_k_fitbit_window_low\": -1.7,\n",
        "            \"log_tau_log_k_fitbit_window_high\": 1.0,\n",
        "        },\n",
        "    }\n",
        "    if rl_int not in presets:\n",
