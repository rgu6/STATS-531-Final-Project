        "        \"fit_scope\": \"masked_only\",\n",
        "        \"section_scope\": \"all\",\n",
        "        \"global_seed\": 531,\n",
        "        \"smoother_scope\": \"none\",\n",
        "        \"smoother_method\": \"backward_particle\",\n",
        "        \"backward_smoother_particles\": None,\n",
        "        \"backward_smoother_trajectories\": 80,\n",
        "        \"backward_smoother_seed\": None,\n",
        "        \"analysis_start_utc_iso\": \"2024-07-01T00:00:00+00:00\",\n",
