        "    return presets[rl_int]\n",
        "\n",
        "\n",
        "def resolve_config(raw_params: dict[str, object]) -> dict[str, object]:\n",
        "    defaults = get_rl_defaults(int(raw_params.get(\"RL\", 0)))\n",
        "    resolved = dict(defaults)\n",
        "    for key, value in raw_params.items():\n",
        "        if value is None:\n",
        "            continue\n",
        "        if isinstance(value, str) and value == \"\":\n",
        "            continue\n",
        "        resolved[key] = value\n",
        "    resolved[\"RL\"] = int(resolved[\"RL\"])\n",
        "    resolved[\"missing_fraction\"] = float(resolved[\"missing_fraction\"])\n",
        "    resolved[\"mask_seed\"] = int(resolved[\"mask_seed\"])\n",
        "    resolved[\"n_mask_replicates\"] = int(resolved[\"n_mask_replicates\"])\n",
        "    resolved[\"global_seed\"] = int(resolved[\"global_seed\"])\n",
        "    if resolved.get(\"panel_chunk_size\") is not None:\n",
        "        resolved[\"panel_chunk_size\"] = int(resolved[\"panel_chunk_size\"])\n",
        "    for name in (\n",
        "        \"stage1_starts\",\n",
        "        \"stage2_starts\",\n",
        "        \"stage1_keep_top\",\n",
        "        \"stage2_keep_top\",\n",
        "        \"stage1_particles\",\n",
        "        \"stage2_particles\",\n",
        "        \"stage1_if2_iterations\",\n",
        "        \"stage2_if2_iterations\",\n",
        "        \"stage1_eval_particles\",\n",
        "        \"stage2_eval_particles\",\n",
        "        \"stage1_eval_reps\",\n",
        "        \"stage2_eval_reps\",\n",
        "        \"stage1_fresh_random_starts\",\n",
        "        \"stage2_fresh_random_starts\",\n",
        "        \"stage1_jittered_restarts\",\n",
        "        \"stage2_jittered_restarts\",\n",
        "        \"backward_smoother_particles\",\n",
        "        \"backward_smoother_trajectories\",\n",
        "        \"backward_smoother_seed\",\n",
        "    ):\n",
        "        if resolved.get(name) is not None:\n",
        "            resolved[name] = int(resolved[name])\n",
        "    for name in (\n",
        "        \"cooling_fraction\",\n",
        "        \"rw_sd_scale\",\n",
        "        \"stage1_cooling_fraction\",\n",
        "        \"stage2_cooling_fraction\",\n",
        "        \"stage1_rw_sd_scale\",\n",
        "        \"stage2_rw_sd_scale\",\n",
        "        \"phi_window_low\",\n",
        "        \"phi_window_high\",\n",
        "        \"phi1_window_low\",\n",
        "        \"phi1_window_high\",\n",
        "        \"phi2_window_low\",\n",
        "        \"phi2_window_high\",\n",
        "        \"phi24_window_low\",\n",
        "        \"phi24_window_high\",\n",
        "        \"sigma_window_low\",\n",
        "        \"sigma_window_high\",\n",
        "        \"k_fitbit_window_low\",\n",
        "        \"k_fitbit_window_high\",\n",
        "        \"log_k_fitbit_window_low\",\n",
        "        \"log_k_fitbit_window_high\",\n",
        "        \"mu_log_k_fitbit_window_low\",\n",
        "        \"mu_log_k_fitbit_window_high\",\n",
        "        \"log_tau_log_k_fitbit_window_low\",\n",
        "        \"log_tau_log_k_fitbit_window_high\",\n",
        "        \"eta_wear_lag1_window_low\",\n",
        "        \"eta_wear_lag1_window_high\",\n",
        "        \"wear_phi_window_low\",\n",
        "        \"wear_phi_window_high\",\n",
        "        \"wear_sigma_window_low\",\n",
        "        \"wear_sigma_window_high\",\n",
        "    ):\n",
        "        if resolved.get(name) is not None:\n",
        "            resolved[name] = float(resolved[name])\n",
        "    if resolved.get(\"stage1_cooling_fraction\") is None:\n",
        "        resolved[\"stage1_cooling_fraction\"] = float(resolved[\"cooling_fraction\"])\n",
        "    if resolved.get(\"stage2_cooling_fraction\") is None:\n",
        "        resolved[\"stage2_cooling_fraction\"] = float(resolved[\"cooling_fraction\"])\n",
        "    if resolved.get(\"stage1_rw_sd_scale\") is None:\n",
        "        resolved[\"stage1_rw_sd_scale\"] = float(resolved[\"rw_sd_scale\"])\n",
        "    if resolved.get(\"stage2_rw_sd_scale\") is None:\n",
        "        resolved[\"stage2_rw_sd_scale\"] = float(resolved[\"rw_sd_scale\"])\n",
        "    for name in (\n",
        "        \"stage1_fresh_random_starts\",\n",
        "        \"stage2_fresh_random_starts\",\n",
        "        \"stage1_jittered_restarts\",\n",
        "        \"stage2_jittered_restarts\",\n",
        "    ):\n",
        "        if resolved.get(name) is None:\n",
        "            resolved[name] = 0\n",
        "    resolved[\"smoother_scope\"] = str(resolved.get(\"smoother_scope\", \"none\")).strip().lower()\n",
        "    if resolved[\"smoother_scope\"] not in {\"none\", \"from_cache_only\", \"compute_missing_only\"}:\n",
        "        raise ValueError(\"smoother_scope must be one of: none, from_cache_only, compute_missing_only\")\n",
        "    resolved[\"smoother_method\"] = str(resolved.get(\"smoother_method\", \"backward_particle\")).strip().lower()\n",
        "    if resolved[\"smoother_method\"] != \"backward_particle\":\n",
        "        raise ValueError(\"smoother_method currently supports only: backward_particle\")\n",
        "    if resolved.get(\"backward_smoother_trajectories\") is None:\n",
        "        resolved[\"backward_smoother_trajectories\"] = 80\n",
        "    return resolved\n",
        "\n",
        "\n",
        "RAW_PARAMS = _raw_params()\n",
        "RESOLVED_CONFIG = resolve_config(RAW_PARAMS)\n",
        "\n",
        "MODEL_SET_REGISTRY = {\n",
        "    \"single\": [],\n",
        "    \"smoke\": [\"ar1\", \"arma_aic\"],\n",
        "    \"core\": [\n",
        "        \"ar1\",\n",
        "        \"ar2\",\n",
        "        \"wear_observation\",\n",
        "        \"wear_latent\",\n",
        "        \"ar2_wear_observation\",\n",
        "        \"ar2_wear_latent\",\n",
        "        \"arma_aic\",\n",
        "    ],\n",
        "    \"all\": [\n",
        "        \"ar1\",\n",
        "        \"ar2\",\n",
        "        \"wear_observation\",\n",
        "        \"wear_latent\",\n",
        "        \"ar2_wear_observation\",\n",
        "        \"ar2_wear_latent\",\n",
        "        \"arma_aic\",\n",
        "    ],\n",
        "}\n",
        "\n",
        "POOLING_MODE_OPTIONS = [\n",
        "    \"unit_specific\",\n",
        "    \"global_shared_k\",\n",
        "    \"partial_pooled_k\",\n",
        "]\n",
        "\n",
        "GLOBAL_START_BOX_DEFAULTS = {\n",
        "    \"phi\": (-0.95, 0.95),\n",
        "    \"phi1\": (-1.25, 1.25),\n",
        "    \"phi2\": (-0.99, 0.99),\n",
        "    \"phi24\": (-0.99, 0.99),\n",
        "    \"sigma\": (0.05, 2.00),\n",
        "    \"k_fitbit\": (0.01, 10.0),\n",
        "    \"log_k_fitbit\": (-3, 2),\n",
        "    \"mu_log_k_fitbit\": (-3, 2),\n",
        "    \"log_tau_log_k_fitbit\": (-2, 1),\n",
        "    \"eta_wear_lag1\": (-4.0, 4.0),\n",
        "    \"wear_phi\": (-0.99, 0.99),\n",
        "    \"wear_sigma\": (0.05, 2.0),\n",
        "}\n",
        "\n",
        "WINDOW_PARAM_FIELDS = {\n",
        "    \"phi\": (\"phi_window_low\", \"phi_window_high\"),\n",
        "    \"phi1\": (\"phi1_window_low\", \"phi1_window_high\"),\n",
        "    \"phi2\": (\"phi2_window_low\", \"phi2_window_high\"),\n",
        "    \"phi24\": (\"phi24_window_low\", \"phi24_window_high\"),\n",
        "    \"sigma\": (\"sigma_window_low\", \"sigma_window_high\"),\n",
        "    \"k_fitbit\": (\"k_fitbit_window_low\", \"k_fitbit_window_high\"),\n",
        "    \"log_k_fitbit\": (\"log_k_fitbit_window_low\", \"log_k_fitbit_window_high\"),\n",
        "    \"mu_log_k_fitbit\": (\"mu_log_k_fitbit_window_low\", \"mu_log_k_fitbit_window_high\"),\n",
        "    \"log_tau_log_k_fitbit\": (\"log_tau_log_k_fitbit_window_low\", \"log_tau_log_k_fitbit_window_high\"),\n",
        "    \"eta_wear_lag1\": (\"eta_wear_lag1_window_low\", \"eta_wear_lag1_window_high\"),\n",
        "    \"wear_phi\": (\"wear_phi_window_low\", \"wear_phi_window_high\"),\n",
        "    \"wear_sigma\": (\"wear_sigma_window_low\", \"wear_sigma_window_high\"),\n",
        "}\n",
        "\n",
        "\n",
        "def _parameter_window_overrides(config: dict[str, object]) -> dict[str, tuple[float, float]]:\n",
        "    overrides: dict[str, tuple[float, float]] = {}\n",
        "    for param_name, (low_key, high_key) in WINDOW_PARAM_FIELDS.items():\n",
        "        low_value = config.get(low_key)\n",
        "        high_value = config.get(high_key)\n",
        "        if low_value is None and high_value is None:\n",
        "            continue\n",
        "        default_low, default_high = GLOBAL_START_BOX_DEFAULTS[param_name]\n",
        "        resolved_low = float(default_low if low_value is None else low_value)\n",
        "        resolved_high = float(default_high if high_value is None else high_value)\n",
        "        if resolved_low >= resolved_high:\n",
        "            raise ValueError(f\"Search window for {param_name} must satisfy low < high.\")\n",
        "        overrides[param_name] = (resolved_low, resolved_high)\n",
        "    return overrides\n",
        "\n",
        "\n",
        "def _active_model_families(config: dict[str, object]) -> list[str]:\n",
        "    model_set_name = str(config[\"model_set\"])\n",
        "    if model_set_name not in MODEL_SET_REGISTRY:\n",
        "        raise ValueError(f\"Unknown model_set: {model_set_name}\")\n",
        "    families = list(MODEL_SET_REGISTRY[model_set_name])\n",
        "    requested_family = str(config[\"model_family\"])\n",
        "    if requested_family not in families:\n",
        "        families.append(requested_family)\n",
        "    return families\n",
        "\n",
        "\n",
        "def _active_pooling_modes(config: dict[str, object]) -> list[str]:\n",
        "    raw_value = config.get(\"pooling_mode\", \"unit_specific\")\n",
        "    if isinstance(raw_value, str):\n",
        "        stripped = raw_value.strip()\n",
        "        if stripped.lower() == \"all\":\n",
        "            requested = list(POOLING_MODE_OPTIONS)\n",
        "        elif \",\" in stripped:\n",
        "            requested = [part.strip() for part in stripped.split(\",\") if part.strip()]\n",
        "        else:\n",
        "            requested = [stripped]\n",
        "    elif isinstance(raw_value, (list, tuple, set)):\n",
        "        requested = [str(item).strip() for item in raw_value if str(item).strip()]\n",
        "    else:\n",
        "        requested = [str(raw_value).strip()]\n",
        "\n",
        "    active_modes: list[str] = []\n",
        "    for mode in requested:\n",
        "        if mode not in POOLING_MODE_OPTIONS:\n",
        "            raise ValueError(f\"Unknown pooling_mode: {mode}\")\n",
        "        if mode not in active_modes:\n",
        "            active_modes.append(mode)\n",
        "    if not active_modes:\n",
        "        raise ValueError(\"At least one pooling mode must be selected.\")\n",
        "    return active_modes\n",
        "\n",
        "\n",
        "RESOLVED_CONFIG[\"active_model_families\"] = _active_model_families(RESOLVED_CONFIG)\n",
        "RESOLVED_CONFIG[\"active_pooling_modes\"] = _active_pooling_modes(RESOLVED_CONFIG)\n",
        "PARAMETER_WINDOW_OVERRIDES = _parameter_window_overrides(RESOLVED_CONFIG)\n",
        "RESOLVED_CONFIG[\"search_windows\"] = {\n",
        "    **GLOBAL_START_BOX_DEFAULTS,\n",
        "    **PARAMETER_WINDOW_OVERRIDES,\n",
        "}\n",
        "\n",
        "CACHE_ROOT = PROJECT_ROOT / \"cache\" / \"computedraft\" / str(RESOLVED_CONFIG[\"cache_version\"]) / str(RESOLVED_CONFIG[\"artifact_tag\"])\n",
        "CACHE_PATHS = {\n",
        "    \"root\": CACHE_ROOT,\n",
        "    \"base\": CACHE_ROOT / \"base\",\n",
        "    \"masks\": CACHE_ROOT / \"masks\",\n",
        "    \"fits_unmasked\": CACHE_ROOT / \"fits\" / \"unmasked\",\n",
        "    \"fits_masked\": CACHE_ROOT / \"fits\" / \"masked\",\n",
        "    \"benchmarks\": CACHE_ROOT / \"benchmarks\",\n",
        "    \"derived\": CACHE_ROOT / \"derived\",\n",
        "    \"manifests\": CACHE_ROOT / \"manifests\",\n",
        "    \"logs\": CACHE_ROOT / \"logs\",\n",
        "    \"report_exports\": CACHE_ROOT / \"report_exports\",\n",
        "}\n",
        "for path in CACHE_PATHS.values():\n",
        "    path.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "requested_device = str(RESOLVED_CONFIG[\"device\"]).strip().lower()\n",
        "if requested_device not in {\"cpu\", \"gpu\"}:\n",
        "    raise ValueError(f\"device must be 'cpu' or 'gpu', got {RESOLVED_CONFIG['device']!r}\")\n",
        "# Native Windows preview runs should stay on CPU even when the report defaults\n",
        "# to RL=2, because the cached-report workflow does not need CUDA there and the\n",
        "# local Windows JAX stack is CPU-oriented.\n",
        "effective_device = requested_device\n",
        "if os.name == \"nt\" and requested_device == \"gpu\":\n",
        "    effective_device = \"cpu\"\n",
        "\n",
        "RESOLVED_CONFIG[\"requested_device\"] = requested_device\n",
        "RESOLVED_CONFIG[\"effective_device\"] = effective_device\n",
        "os.environ[\"JAX_PLATFORMS\"] = \"cuda\" if effective_device == \"gpu\" else \"cpu\"\n",
        "\n",
        "SEARCH_STAGE_SETTINGS = [\n",
        "    {\n",
        "        \"name\": \"Stage 1\",\n",
        "        \"n_starts\": int(RESOLVED_CONFIG[\"stage1_starts\"]),\n",
        "        \"keep_top\": int(RESOLVED_CONFIG[\"stage1_keep_top\"]),\n",
        "        \"particles\": int(RESOLVED_CONFIG[\"stage1_particles\"]),\n",
        "        \"mif_iterations\": int(RESOLVED_CONFIG[\"stage1_if2_iterations\"]),\n",
        "        \"cooling_fraction\": float(RESOLVED_CONFIG[\"stage1_cooling_fraction\"]),\n",
        "        \"rw_sd_scale\": float(RESOLVED_CONFIG[\"stage1_rw_sd_scale\"]),\n",
        "        \"evaluation_particles\": int(RESOLVED_CONFIG[\"stage1_eval_particles\"]),\n",
        "        \"evaluation_pfilter_reps\": int(RESOLVED_CONFIG[\"stage1_eval_reps\"]),\n",
        "        \"n_fresh_random_starts\": int(RESOLVED_CONFIG[\"stage1_fresh_random_starts\"]),\n",
        "        \"n_jittered_restarts\": int(RESOLVED_CONFIG[\"stage1_jittered_restarts\"]),\n",
        "    },\n",
        "    {\n",
        "        \"name\": \"Stage 2\",\n",
        "        \"n_starts\": int(RESOLVED_CONFIG[\"stage2_starts\"]),\n",
        "        \"keep_top\": int(RESOLVED_CONFIG[\"stage2_keep_top\"]),\n",
        "        \"particles\": int(RESOLVED_CONFIG[\"stage2_particles\"]),\n",
        "        \"mif_iterations\": int(RESOLVED_CONFIG[\"stage2_if2_iterations\"]),\n",
        "        \"cooling_fraction\": float(RESOLVED_CONFIG[\"stage2_cooling_fraction\"]),\n",
        "        \"rw_sd_scale\": float(RESOLVED_CONFIG[\"stage2_rw_sd_scale\"]),\n",
        "        \"evaluation_particles\": int(RESOLVED_CONFIG[\"stage2_eval_particles\"]),\n",
        "        \"evaluation_pfilter_reps\": int(RESOLVED_CONFIG[\"stage2_eval_reps\"]),\n",
        "        \"n_fresh_random_starts\": int(RESOLVED_CONFIG[\"stage2_fresh_random_starts\"]),\n",
        "        \"n_jittered_restarts\": int(RESOLVED_CONFIG[\"stage2_jittered_restarts\"]),\n",
        "    },\n",
        "]\n",
        "\n",
        "RESOLVED_CONFIG[\"config_hash\"] = hashlib.sha256(\n",
        "    json.dumps(RESOLVED_CONFIG, sort_keys=True, default=str).encode(\"utf-8\")\n",
        ").hexdigest()[:16]\n",
        "REPORT_EXPORT_FILES = {\n",
        "    \"resolved_config\": CACHE_PATHS[\"report_exports\"] / \"resolved_config.json\",\n",
        "    \"model_comparison\": CACHE_PATHS[\"report_exports\"] / \"model_comparison.csv\",\n",
        "    \"benchmark_summary\": CACHE_PATHS[\"report_exports\"] / \"benchmark_summary.csv\",\n",
        "    \"parameter_summary\": CACHE_PATHS[\"report_exports\"] / \"parameter_summary.csv\",\n",
        "    \"timing_summary\": CACHE_PATHS[\"report_exports\"] / \"timing_summary.csv\",\n",
        "    \"task_manifest\": CACHE_PATHS[\"report_exports\"] / \"task_manifest.csv\",\n",
        "    \"cohort_summary\": CACHE_PATHS[\"report_exports\"] / \"cohort_summary.json\",\n",
        "}\n",
        "REPORT_EXPORT_REQUIRED_KEYS = [\n",
        "    \"resolved_config\",\n",
        "    \"model_comparison\",\n",
        "    \"benchmark_summary\",\n",
        "    \"parameter_summary\",\n",
        "    \"timing_summary\",\n",
        "    \"task_manifest\",\n",
        "    \"cohort_summary\",\n",
        "]\n",
        "RESOLVED_CONFIG[\"report_exports_ready\"] = all(\n",
        "    REPORT_EXPORT_FILES[key].exists() for key in REPORT_EXPORT_REQUIRED_KEYS\n",
        ")\n",
        "EXPECTED_REPORT_BENCHMARK_VERSION = \"v2\""
      ],
      "id": "compute-interface",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "#| label: report-helpers\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import seaborn as sns\n",
        "from IPython.display import display\n",
        "\n",
        "CSV_PATH = PROJECT_ROOT / \"FitbitHourly.csv\"\n",
        "if not CSV_PATH.exists():\n",
        "    raise FileNotFoundError(\"FitbitHourly.csv must be in the same folder as finaldraft.qmd.\")\n",
        "\n",
        "\n",
        "def display_table(\n",
        "    df: pd.DataFrame,\n",
        "    *,\n",
        "    precision: int = 3,\n",
        ") -> None:\n",
        "    styled = df.style.hide(axis=\"index\").format(precision=precision, na_rep=\"\")\n",
        "    display(styled)\n",
        "\n",
        "\n",
        "def make_key_value_table(\n",
        "    mapping: dict[str, object],\n",
        "    *,\n",
        "    key_label: str = \"Setting\",\n",
        "    value_label: str = \"Value\",\n",
        ") -> pd.DataFrame:\n",
        "    return pd.DataFrame(\n",
        "        [{key_label: str(key), value_label: value} for key, value in mapping.items()]\n",
        "    )\n",
        "\n",
        "\n",
        "def model_label(value: object) -> str:\n",
        "    mapping = {\n",
        "        \"ar1\": \"AR(1)\",\n",
        "        \"ar2\": \"AR(2)\",\n",
        "        \"arma_aic\": \"ARMA(AIC)\",\n",
        "        \"wear_observation\": \"Wear Obs\",\n",
        "        \"wear_latent\": \"Wear Latent\",\n",
        "        \"ar2_wear_observation\": \"AR(2) Wear Obs\",\n",
        "        \"ar2_wear_latent\": \"AR(2) Wear Latent\",\n",
        "    }\n",
        "    return mapping.get(str(value), str(value))\n",
        "\n",
        "\n",
        "def pooling_label(value: object) -> str:\n",
        "    mapping = {\n",
        "        \"unit_specific\": \"personal k\",\n",
        "        \"global_shared_k\": \"global k\",\n",
        "        \"partial_pooled_k\": \"partial pooled k\",\n",
        "        \"not_applicable\": \"-\",\n",
        "    }\n",
        "    return mapping.get(str(value), str(value))\n",
        "\n",
        "\n",
        "def estimate_label(value: object) -> str:\n",
        "    mapping = {\n",
        "        \"filter\": \"filter\",\n",
        "        \"smoothed\": \"smoothed\",\n",
        "    }\n",
        "    return mapping.get(str(value), str(value))\n",
        "\n",
        "\n",
        "def read_report_json(path: Path) -> object:\n",
        "    with path.open(\"r\", encoding=\"utf-8\") as handle:\n",
        "        return json.load(handle)\n",
        "\n",
        "\n",
        "def read_report_csv(path: Path) -> pd.DataFrame:\n",
        "    if not path.exists():\n",
        "        return pd.DataFrame()\n",
        "    try:\n",
        "        return pd.read_csv(path)\n",
        "    except pd.errors.EmptyDataError:\n",
        "        return pd.DataFrame()\n",
        "\n",
        "\n",
        "def load_report_exports(file_map: dict[str, Path]) -> dict[str, object]:\n",
        "    payload: dict[str, object] = {}\n",
        "    for key, path in file_map.items():\n",
        "        if path.suffix.lower() == \".csv\":\n",
        "            payload[key] = read_report_csv(path)\n",
        "        else:\n",
        "            payload[key] = read_report_json(path)\n",
        "    return payload\n",
        "\n",
        "\n",
        "def report_exports_cover_active_results(\n",
        "    payload: dict[str, object],\n",
        "    *,\n",
        "    active_model_families: list[str],\n",
        "    active_pooling_modes: list[str],\n",
        "    expected_benchmark_version: str,\n",
        ") -> bool:\n",
        "    benchmark_summary = pd.DataFrame(payload.get(\"benchmark_summary\", pd.DataFrame())).copy()\n",
        "    if benchmark_summary.empty:\n",
        "        return False\n",
        "    if \"benchmark_version\" not in benchmark_summary.columns:\n",
        "        return False\n",
        "    benchmark_versions = {\n",
        "        str(value)\n",
        "        for value in benchmark_summary[\"benchmark_version\"].dropna().astype(str).tolist()\n",
        "    }\n",
        "    if expected_benchmark_version not in benchmark_versions:\n",
        "        return False\n",
        "    for model_family in active_model_families:\n",
        "        family_rows = benchmark_summary.loc[\n",
        "            benchmark_summary[\"model_family\"].astype(str) == str(model_family)\n",
        "        ].copy()\n",
        "        if family_rows.empty:\n",
        "            return False\n",
        "        expected_pooling_modes = (\n",
        "            {\"not_applicable\"} if str(model_family) == \"arma_aic\" else set(map(str, active_pooling_modes))\n",
        "        )\n",
        "        present_pooling_modes = set(family_rows[\"pooling_mode\"].astype(str).tolist())\n",
        "        if not expected_pooling_modes.issubset(present_pooling_modes):\n",
        "            return False\n",
        "    return True"
      ],
      "id": "report-helpers",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Introduction\n",
        "\n",
        "## Background Information and Project Motivation\n",
        "\n",
        "For a new medical school graduate, the first year of residency is demanding and stressful. The yearly Intern Health Study (IHS) aims to study the effect of stress on mental health outcomes, enrolling over a thousand new interns each year. @internhealthstudy The study collects large amounts of data on interns including quarterly psychological surveys, DNA samples, daily mood scores, and sleep and physical activity data from wearable devices. In this project, we focus only on physical activity measured by step count in the 2024 IHS.\n",
        "\n",
        "In addition to collecting data, recent iterations of the IHS are incorporating reinforcement-learning based mobile health interventions. At 3:00 p.m. each day, an agent decides based on the participant's context whether to send a participant a message, with some learned probability. This randomized setup allows researchers to study whether these messages influence participant behavior. In this context, the objective is to increase physical activity, so step count serves as the reward outcome of interest. To be precise, the reward for a given day is the number of steps a user takes in the 24 hours after the 3 p.m. decision point in local time.\n",
        "\n",
        "Reinforcement learning and contextual bandit methods are becoming increasingly important in healthcare because they enable personalized interventions. In digital health, these methods can be used to decide when and how to deliver prompts that encourage healthier behaviors, such as increasing physical activity or improving medication adherence. Contextual bandits are especially useful because they incorporate patient characteristics when selecting an action. For example, RoME is a robust contextual bandit method for mobile health applications that determines when to send notifications and how to personalize interventions based on a user's current situation. @RoME Similarly, Oralytics is a mobile health intervention system that uses an online reinforcement learning algorithm to determine optimal times to deliver interventions that promote oral self-care behaviors. @Oralytics\n",
        "\n",
        "This project is motivated by the growing need to apply these methods in realistic settings where data are often incomplete. In our dataset, missingness occurs when users do not wear their devices, which leads to gaps in the recorded activity data. Missing data can distort the information available to the algorithm and may ultimately affect its behavior and performance. As a result, robust strategies for handling delayed and missing data are essential so that the algorithm can continue to function reliably and produce reproducible results. @DigitalHealth\n",
        "\n",
        "## Past Project Context\n",
        "\n",
        "Most past projects centered on infectious disease or financial topics. There was one project that also looked at measurements from wearable devices @HeartRate. That project focused on the instantaneous effect of environmental noise on heart rate variability, while ours is primarily about predicting step count in the next 24 hours following a motivating message sent to study participants.\n",
        "\n",
        "Both projects face the same issue of missing data. The heart rate variability project pooled all participants together into a population-level daily summary, taking the median measurement of each day. While we initially designed Partially Observed Markov Process (POMP) models for individual participants, we also incorporated global and partial pooling to jointly learn measurement dispersion parameters across participants in a compute-intensive, high-parameter panel POMP system. We did not find prior course projects that focused on prediction of missing activity data or implemented a panel POMP, so we emphasize predictive model selection on masked data rather than scientific inference.\n",
        "\n",
        "## Research Question\n",
        "\n",
        "When a participant does not wear the watch, no step count data are collected during that period. On days when the watch is worn for only a short time, or not at all, a reward cannot be constructed, so that day provides no training information for the reinforcement learning based intervention. The goal of this project is to build personalized POMP models for each doctor and to estimate the missing rewards.\n",
        "\n",
        "# Exploratory Data Analysis\n",
        "\n",
        "Participants wear devices from Garmin, Fitbit, and Apple, and some individuals may use more than one device. Since these devices differ in how they record and store data, as well as behavioral differences in device ownership, the data streams cannot be combined perfectly. While joint measurement models across devices would be valuable, due to time and compute constraints, we limit ourselves to Fitbit users.\n",
        "\n",
        "For this project, we focused only on users who had Fitbit data. Since few users had Garmin devices, it would be difficult to train the model, and Apple HealthKit acts as a central repository for health and fitness data which combines information from both phones and watches and may aggregate step counts originating from other wearables. We found it difficult to disentangle the biases associated with Apple-based measurements.\n",
        "\n",
        "The `FitbitHourly.csv` file contains data from 299 participants with Fitbit data. We limited our analysis to the period from July 1, 2024, to September 30, 2024, the first three months of IHS 2024. Additionally, we filtered to participants with Fitbit step data in at least half of their hourly rows, which left us with 78 participants."
      ],
      "id": "264a1dd4"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "#| label: eda-read-data\n",
        "\n",
        "df = pd.read_csv(CSV_PATH)\n",
        "prune_df = df.loc[(df[\"date_utc\"] >= \"2024-07-01\") & (df[\"date_utc\"] <= \"2024-09-30\")].copy()\n",
        "\n",
        "valid_ids = (\n",
        "    prune_df.groupby(\"PARTICIPANTIDENTIFIER\")[\"fitbitStepsMissing\"]\n",
        "    .sum()\n",
        "    .loc[lambda s: s <= 1104]\n",
        "    .index\n",
        ")\n",
        "prune_df = prune_df.loc[prune_df[\"PARTICIPANTIDENTIFIER\"].isin(valid_ids)].copy()"
      ],
      "id": "eda-read-data",
      "execution_count": null,
      "outputs": []
    },
    {
