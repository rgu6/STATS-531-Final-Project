      "source": [
        "#| echo: false\n",
        "#| label: aggregate-model-comparison\n",
        "\n",
        "if aggregate_model_comparison.empty:\n",
        "    print(\"No aggregate benchmark summaries are available for the current fit_scope / section_scope configuration.\")\n",
        "else:\n",
        "    comparison_display = aggregate_model_comparison.copy()\n",
        "    sort_columns = [\n",
        "        column\n",
        "        for column in [\"benchmark_label\", \"heldout_subtotal_rmse_sqrtm\", \"hourly_masked_rmse\", \"model_family\", \"pooling_mode\"]\n",
        "        if column in comparison_display.columns\n",
        "    ]\n",
        "    if sort_columns:\n",
        "        comparison_display = comparison_display.sort_values(\n",
        "            sort_columns,\n",
        "            ascending=[True] * len(sort_columns),\n",
        "            na_position=\"last\",\n",
        "        ).reset_index(drop=True)\n",
        "    else:\n",
        "        comparison_display = comparison_display.reset_index(drop=True)\n",
        "    for table_title, table_frame in build_model_comparison_tables(comparison_display):\n",
        "        print(table_title)\n",
        "        display_table(table_frame, precision=3)"
      ],
      "id": "aggregate-model-comparison",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "#| label: aggregate-model-metric-summary\n",
        "\n",
        "if aggregate_model_metric_summary.empty:\n",
        "    print(\"No participant-averaged model metric summary is available.\")\n",
        "else:\n",
        "    print(\"Participant-averaged metrics. These differ from the pooled benchmark table above because each participant contributes one score before averaging.\")\n",
        "    model_metric_display = (\n",
        "        aggregate_model_metric_summary.assign(\n",
        "            pooling_mode=lambda df: df[\"pooling_mode\"].astype(str).replace(\n",
        "                {\n",
        "                    \"unit_specific\": \"unit\",\n",
        "                    \"global_shared_k\": \"global_k\",\n",
        "                    \"partial_pooled_k\": \"partial_k\",\n",
        "                    \"not_applicable\": \"-\",\n",
        "                }\n",
        "            )\n",
        "        ).loc[\n",
        "            :,\n",
        "            [\n",
        "                column\n",
        "                for column in [\n",
        "                    \"model_family\",\n",
        "                    \"pooling_mode\",\n",
        "                    \"mean_panel_unit_loglik\",\n",
        "                    \"hourly_rmse\",\n",
        "                    \"reward_rmse\",\n",
        "                    \"daily_rmse_sqrtm\",\n",
        "                ]\n",
        "                if column in aggregate_model_metric_summary.columns\n",
        "            ],\n",
        "        ]\n",
        "        .rename(\n",
        "            columns={\n",
        "                \"model_family\": \"model\",\n",
        "                \"pooling_mode\": \"pooling\",\n",
        "                \"mean_panel_unit_loglik\": \"avg logLik\",\n",
        "                \"hourly_rmse\": \"hr RMSE\",\n",
        "                \"reward_rmse\": \"reward RMSE\",\n",
        "                \"daily_rmse_sqrtm\": \"daily RMSE/sqrt(m)\",\n",
        "            }\n",
        "        )\n",
        "        .sort_values([\"model\", \"pooling\"], na_position=\"last\")\n",
        "        .reset_index(drop=True)\n",
        "    )\n",
        "    display_table(model_metric_display, precision=2)"
      ],
      "id": "aggregate-model-metric-summary",
      "execution_count": null,
      "outputs": []
    },
