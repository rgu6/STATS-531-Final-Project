      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "```{=latex}\n",
        "\\noindent\n",
        "\\begin{minipage}[t]{0.7\\textwidth}\n",
        "\\centering\n",
        "\\refstepcounter{figure}\\label{fig-empirical-mu-logk-window}\n",
        "\\includegraphics[width=\\linewidth]{cache/computedraft/v1/rl2_masked_v4/report_exports/plots/empirical_mu_logk_vs_log_tau_personal_partial.png}\n",
        "\\end{minipage}\\hfill\n",
        "\\begin{minipage}[t]{0.28\\textwidth}\n",
        "\\centering\n",
        "\\refstepcounter{table}\\label{tbl-inference-search-window}\n",
        "\\includegraphics[width=\\linewidth]{cache/computedraft/v1/rl2_masked_v4/report_exports/plots/inference_search_window_table_inline.png}\n",
        "\\end{minipage}\n",
        "```\n",
        "\n",
        "# Results\n",
        "\n",
        "Next, we fit the three primary models, as well as ARMA. The ARMA $(p, q)$ is picked by best scoring on AIC independently for each individual. After fitting the three primary models, we make predictions in one pass with a filter (labeling these globalfilter, partialfilter, and personalfilter), then perform the natural smoother with a following backward pass across the data (likewise named globalsmooth, partialsmooth, personalsmooth)."
      ],
      "id": "1fe8ad58"
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "#| label: aggregate-results-imports\n",
        "\n",
        "aggregate_config = dict(RESOLVED_CONFIG)\n",
        "aggregate_config[\"search_stage_settings\"] = SEARCH_STAGE_SETTINGS\n",
        "\n",
        "aggregate_export_payload: dict[str, object] = {}\n",
        "aggregate_result = None\n",
        "report_exports_exist = all(REPORT_EXPORT_FILES[key].exists() for key in REPORT_EXPORT_REQUIRED_KEYS)\n",
        "use_report_exports = False\n",
        "\n",
        "if str(aggregate_config[\"cache_mode\"]) != \"force_recompute\" and report_exports_exist:\n",
        "    # Report exports are plain CSV/JSON artifacts so preview renders can avoid\n",
        "    # importing the heavy JAX / pypomp stack when cached results already exist.\n",
        "    aggregate_export_payload = load_report_exports(REPORT_EXPORT_FILES)\n",
        "    use_report_exports = report_exports_cover_active_results(\n",
        "        aggregate_export_payload,\n",
        "        active_model_families=list(map(str, aggregate_config[\"active_model_families\"])),\n",
        "        active_pooling_modes=list(map(str, aggregate_config[\"active_pooling_modes\"])),\n",
        "        expected_benchmark_version=EXPECTED_REPORT_BENCHMARK_VERSION,\n",
        "    )\n",
        "\n",
        "if not use_report_exports:\n",
        "    import jax\n",
        "\n",
        "    jax_backend = str(jax.default_backend())\n",
        "    if effective_device == \"gpu\":\n",
        "        gpu_devices = [device for device in jax.devices() if device.platform == \"gpu\"]\n",
        "        if not gpu_devices or jax_backend != \"gpu\":\n",
        "            raise RuntimeError(\n",
        "                \"device='gpu' was requested in finaldraft.qmd, but JAX did not initialize a GPU backend. \"\n",
        "                f\"default_backend={jax_backend!r}, devices={[device.platform for device in jax.devices()]!r}\"\n",
        "            )\n",
        "    elif jax_backend != \"cpu\":\n",
        "        raise RuntimeError(\n",
        "            \"device='cpu' was requested in finaldraft.qmd, but JAX initialized a different backend. \"\n",
        "            f\"default_backend={jax_backend!r}\"\n",
        "        )\n",
        "\n",
        "    from helpers.computedraft_pipeline import run_cache_first_pipeline\n",
        "\n",
        "    aggregate_result = run_cache_first_pipeline(\n",
        "        CSV_PATH,\n",
        "        resolved_config=aggregate_config,\n",
        "        cache_paths=CACHE_PATHS,\n",
        "        active_model_families=list(aggregate_config[\"active_model_families\"]),\n",
        "        active_pooling_modes=list(aggregate_config[\"active_pooling_modes\"]),\n",
        "        progress_callback=lambda message: print(message, flush=True),\n",
        "    )"
      ],
      "id": "aggregate-results-imports",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "message": false
      },
      "source": [
        "#| echo: false\n",
        "#| warning: false\n",
        "#| label: aggregate-results-derived\n",
        "\n",
        "if use_report_exports:\n",
        "    aggregate_task_manifest = pd.DataFrame(aggregate_export_payload.get(\"task_manifest\", pd.DataFrame())).copy()\n",
        "    aggregate_model_comparison = pd.DataFrame(aggregate_export_payload.get(\"model_comparison\", pd.DataFrame())).copy()\n",
        "    aggregate_benchmark_summary = pd.DataFrame(aggregate_export_payload.get(\"benchmark_summary\", pd.DataFrame())).copy()\n",
        "    aggregate_parameter_summary = pd.DataFrame(aggregate_export_payload.get(\"parameter_summary\", pd.DataFrame())).copy()\n",
        "    aggregate_timing_summary = pd.DataFrame(aggregate_export_payload.get(\"timing_summary\", pd.DataFrame())).copy()\n",
        "    aggregate_masked_fits = {}\n",
        "    exported_cohort_summary = dict(aggregate_export_payload.get(\"cohort_summary\", {}))\n",
        "else:\n",
        "    aggregate_task_manifest = aggregate_result.task_manifest.copy()\n",
        "    aggregate_derived_artifact = aggregate_result.derived_artifact\n",
        "    aggregate_model_comparison = aggregate_derived_artifact.get(\"model_comparison\", pd.DataFrame()).copy()\n",
        "    aggregate_benchmark_summary = aggregate_derived_artifact.get(\"benchmark_summary\", pd.DataFrame()).copy()\n",
        "    aggregate_parameter_summary = aggregate_derived_artifact.get(\"parameter_summary\", pd.DataFrame()).copy()\n",
        "    aggregate_timing_summary = aggregate_result.timing_summary.copy()\n",
        "    aggregate_masked_fits = aggregate_derived_artifact.get(\"masked_fits\", {})\n",
        "    exported_cohort_summary = {\n",
        "        \"selected_participants\": len(aggregate_derived_artifact.get(\"participant_ids\", [])),\n",
        "        \"full_set_participants\": len(aggregate_result.base_artifact.get(\"full_set_ids\", [])),\n",
        "        \"small_set_participants\": len(aggregate_result.base_artifact.get(\"small_set_ids\", [])),\n",
        "    }\n",
        "\n",
        "if aggregate_parameter_summary.empty and aggregate_masked_fits:\n",
        "    parameter_rows = []\n",
        "    seen_model_pooling = set()\n",
        "    for (model_family, pooling_mode, mask_id), artifact in sorted(aggregate_masked_fits.items()):\n",
        "        key = (str(model_family), str(pooling_mode))\n",
        "        if key in seen_model_pooling:\n",
        "            continue\n",
        "        participant_estimates = artifact.get(\"participant_estimates\", pd.DataFrame()).copy()\n",
        "        if participant_estimates.empty:\n",
        "            continue\n",
        "        participant_estimates[\"model_family\"] = str(model_family)\n",
        "        participant_estimates[\"pooling_mode\"] = str(pooling_mode)\n",
        "        participant_estimates[\"mask_id\"] = str(mask_id)\n",
        "        parameter_rows.append(participant_estimates)\n",
        "        seen_model_pooling.add(key)\n",
        "    if parameter_rows:\n",
        "        aggregate_parameter_summary = pd.concat(parameter_rows, ignore_index=True)\n",
        "\n",
        "if (\n",
        "    not aggregate_model_comparison.empty\n",
        "    and not aggregate_parameter_summary.empty\n",
        "    and {\"model_family\", \"pooling_mode\", \"panel_unit_loglik\"}.issubset(aggregate_parameter_summary.columns)\n",
        "):\n",
        "    mean_loglik_by_model = (\n",
        "        aggregate_parameter_summary.groupby([\"model_family\", \"pooling_mode\"], as_index=False)\n",
        "        .agg(mean_panel_unit_loglik=(\"panel_unit_loglik\", lambda s: float(pd.to_numeric(s, errors=\"coerce\").mean())))\n",
        "    )\n",
        "    aggregate_model_comparison = aggregate_model_comparison.drop(columns=[\"mean_panel_unit_loglik\"], errors=\"ignore\").merge(\n",
        "        mean_loglik_by_model,\n",
        "        how=\"left\",\n",
        "        on=[\"model_family\", \"pooling_mode\"],\n",
        "    )\n",
        "\n",
        "if not aggregate_model_comparison.empty and \"estimate_type\" not in aggregate_model_comparison.columns:\n",
        "    aggregate_model_comparison[\"estimate_type\"] = \"filter\"\n",
        "\n",
        "parameter_model_summary = pd.DataFrame()\n",
        "if not aggregate_parameter_summary.empty and {\"model_family\", \"pooling_mode\"}.issubset(aggregate_parameter_summary.columns):\n",
        "    parameter_model_summary = (\n",
        "        aggregate_parameter_summary.groupby([\"model_family\", \"pooling_mode\"], as_index=False)\n",
        "        .agg(\n",
        "            mean_phi=(\"phi\", \"mean\"),\n",
        "            mean_sigma=(\"sigma\", \"mean\"),\n",
        "            mean_k=(\"k_fitbit\", \"mean\"),\n",
        "            sd_k=(\"k_fitbit\", \"std\"),\n",
        "        )\n",
        "    )\n",
        "\n",
        "aggregate_cohort_summary = {\n",
        "    \"Selected participants\": int(\n",
        "        exported_cohort_summary.get(\n",
        "            \"selected_participants\",\n",
        "            aggregate_parameter_summary[\"participant_id\"].nunique() if \"participant_id\" in aggregate_parameter_summary.columns else 0,\n",
        "        )\n",
        "    ),\n",
        "    \"Full-set participants\": int(exported_cohort_summary.get(\"full_set_participants\", 0)),\n",
        "    \"Small-set participants\": int(exported_cohort_summary.get(\"small_set_participants\", 0)),\n",
        "    \"Benchmark rows\": int(len(aggregate_benchmark_summary)),\n",
        "}"
      ],
