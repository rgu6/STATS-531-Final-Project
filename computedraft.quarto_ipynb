    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "#| label: aggregate-search-windows\n",
        "\n",
        "if str(aggregate_config[\"section_scope\"]) in {\"all\", \"aggregate_only\", \"benchmarks_only\", \"plots_only\"}:\n",
