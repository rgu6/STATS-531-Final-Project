        "#| echo: false\n",
        "#| label: aggregate-benchmark-plot\n",
        "\n",
        "if not aggregate_model_comparison.empty and str(aggregate_config[\"section_scope\"]) in {\"all\", \"benchmarks_only\", \"plots_only\"}:\n",
        "    plot_df = aggregate_model_comparison.copy()\n",
        "    if \"benchmark_label\" in plot_df.columns and plot_df[\"benchmark_label\"].notna().any():\n",
        "        selected_benchmark_label = str(plot_df[\"benchmark_label\"].dropna().astype(str).iloc[0])\n",
        "        plot_df = plot_df.loc[plot_df[\"benchmark_label\"].astype(str) == selected_benchmark_label].copy()\n",
        "    else:\n",
        "        selected_benchmark_label = \"Aggregate benchmark comparison\"\n",
        "    metric_column = \"heldout_subtotal_rmse_sqrtm\" if \"heldout_subtotal_rmse_sqrtm\" in plot_df.columns else None\n",
        "    if metric_column is None:\n",
        "        numeric_columns = [\n",
        "            column\n",
        "            for column in plot_df.columns\n",
        "            if column not in {\"model_family\", \"pooling_mode\", \"benchmark_key\", \"benchmark_label\"}\n",
        "            and pd.api.types.is_numeric_dtype(pd.to_numeric(plot_df[column], errors=\"coerce\"))\n",
        "        ]\n",
        "        metric_column = numeric_columns[0] if numeric_columns else None\n",
        "    if metric_column is not None:\n",
        "        fig, ax = plt.subplots(figsize=(8, 4.5))\n",
        "        x_labels = plot_df[\"model_family\"].astype(str)\n",
        "        if \"pooling_mode\" in plot_df.columns:\n",
        "            x_labels = x_labels + \" / \" + plot_df[\"pooling_mode\"].astype(str)\n",
        "        ax.bar(\n",
        "            x_labels,\n",
        "            pd.to_numeric(plot_df[metric_column], errors=\"coerce\"),\n",
        "            color=\"#d4a72c\",\n",
        "            edgecolor=\"#7a5f12\",\n",
        "        )\n",
        "        ylabel = \"Held-out subtotal RMSE / sqrt(m)\" if metric_column == \"heldout_subtotal_rmse_sqrtm\" else str(metric_column)\n",
        "        ax.set_ylabel(ylabel)\n",
        "        ax.set_xlabel(\"Model family / pooling\")\n",
        "        ax.set_title(selected_benchmark_label)\n",
        "        ax.tick_params(axis=\"x\", rotation=35)\n",
        "        plt.tight_layout()\n",
        "        plt.show()"
      ],
      "id": "aggregate-benchmark-plot",
