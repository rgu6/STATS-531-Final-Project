        "  stage2_jittered_restarts: null\n",
        "  smoother_scope: null            # null = use RL preset; none | from_cache_only | compute_missing_only\n",
        "  smoother_method: null           # null = use RL preset; currently only backward_particle\n",
        "  backward_smoother_particles: null\n",
        "  backward_smoother_trajectories: null\n",
        "  backward_smoother_seed: null\n",
