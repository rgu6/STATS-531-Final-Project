      "source": [
        "---\n",
        "title: \"Predicting Missing Wearable Device Data with Panel POMP \\\\vspace{-2cm}\"\n",
        "bibliography: references.bib\n",
        "nocite: \"@*\"\n",
        "csl: ieee.csl\n",
        "params:\n",
        "  RL: 2\n",
        "  device: null                    # null = use RL preset; \"cpu\" | \"gpu\"\n",
        "  cache_mode: null                # null = use RL preset; prefer_cache | recompute_missing_only | force_recompute\n",
        "  cache_version: \"v1\"\n",
        "  artifact_tag: null              # null = use RL preset\n",
        "  participant_set: null           # null = use RL preset; \"small_set\" | \"full_set\"\n",
        "  model_set: null                 # null = use RL preset; \"single\" | \"smoke\" | \"core\" | \"all\"\n",
        "  model_family: null              # null = use RL preset; e.g. \"ar1\" | \"arma_aic\"\n",
        "  pooling_mode: null              # null = use RL preset; string, csv string, YAML list, or \"all\"\n",
        "  covariate_mode: null\n",
