      "source": [
        "---\n",
        "title: \"Predicting Missing Wearable Device Data with Panel POMP \\\\vspace{-2cm}\"\n",
        "jupyter: python3\n",
        "bibliography: references.bib\n",
        "nocite: \"@*\"\n",
        "csl: ieee.csl\n",
        "params:\n",
        "  RL: 2\n",
        "  device: null                    # null = use RL preset; \"cpu\" | \"gpu\"\n",
        "  cache_mode: \"prefer_cache\"      # default cached render path\n",
        "  cache_version: \"v1\"\n",
        "  artifact_tag: \"rl2_masked_v4\"   # default RL=2 cached artifact bundle\n",
        "  participant_set: null           # null = use RL preset; \"small_set\" | \"full_set\"\n",
        "  model_set: \"smoke\"              # default report model set\n",
        "  model_family: null              # null = use RL preset; e.g. \"ar1\" | \"arma_aic\"\n",
