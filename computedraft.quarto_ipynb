        "cooling_fraction = None\n",
        "rw_sd_scale = None\n",
        "stage1_eval_particles = None\n",
        "stage2_eval_particles = None\n",
        "stage1_eval_reps = None\n",
        "stage2_eval_reps = None\n",
        "stage1_fresh_random_starts = None\n",
        "stage2_fresh_random_starts = None\n",
        "stage1_jittered_restarts = None\n",
