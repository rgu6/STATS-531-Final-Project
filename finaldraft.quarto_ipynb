        "#| echo: false\n",
        "#| include: false\n",
        "#| label: eda-mean-vs-sd-build\n",
        "\n",
        "non_missing = prune_df.loc[prune_df[\"fitbitStepsMissing\"] == 0].copy()\n",
        "non_missing[\"fitbitSteps\"] = pd.to_numeric(non_missing[\"fitbitSteps\"], errors=\"coerce\")\n",
        "non_missing = non_missing.dropna(subset=[\"fitbitSteps\"])\n",
        "\n",
        "stats = non_missing.groupby(\"PARTICIPANTIDENTIFIER\")[\"fitbitSteps\"].agg(\n",
        "    [\"mean\", \"std\"]\n",
        ").reset_index()\n",
        "\n",
        "eda_mean_sd_output_path = CACHE_PATHS[\"report_exports\"] / \"plots\" / \"eda_mean_vs_sd_inline.png\"\n",
        "eda_mean_sd_output_path.parent.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(4.8, 3.6))\n",
        "ax.scatter(stats[\"mean\"], stats[\"std\"], alpha=0.8, s=30)\n",
        "ax.set_xlabel(\"Mean Fitbit steps\", fontsize=10)\n",
        "ax.set_ylabel(\"Standard deviation of Fitbit steps\", fontsize=10)\n",
        "ax.set_title(\"Mean versus variability in non-missing hourly Fitbit steps\", fontsize=11)\n",
        "ax.tick_params(axis=\"both\", labelsize=9)\n",
        "plt.tight_layout()\n",
        "plt.savefig(eda_mean_sd_output_path, dpi=180, bbox_inches=\"tight\")\n",
        "plt.close(fig)"
      ],
