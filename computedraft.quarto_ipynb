{
  "cells": [
    {
      "cell_type": "raw",
      "metadata": {},
      "source": [
        "---\n",
        "title: \"Title of Project (TBD)\\\\vspace{-2cm}\"\n",
        "bibliography: references.bib\n",
        "nocite: \"@*\"\n",
        "csl: ieee.csl\n",
        "params:\n",
        "  RL: 2\n",
        "  device: \"gpu\"\n",
        "  cache_mode: \"prefer_cache\"    # prefer_cache | recompute_missing_only | force_recompute\n",
        "  cache_version: \"v1\"\n",
        "  artifact_tag: \"rl2_masked_v4\"\n",
        "  participant_set: null         # null = RL preset default; \"small_set\" | \"full_set\"\n",
        "  model_set: \"single\"           # null = use RL preset; single | smoke | core | all\n",
        "                                # smoke = ar1 + arma_aic\n",
        "                                # single = just model_family\n",
        "                                # core/all = ar1, ar2, wear_observation, wear_latent,\n",
        "                                #            ar2_wear_observation, ar2_wear_latent, arma_aic\n",
        "  model_family: \"ar1\"\n",
        "                                # model_family options:\n",
        "                                #   \"ar1\"                  = AR(1) + empirical hour/day baseline\n",
        "                                #   \"ar2\"                  = AR(2) + empirical hour/day baseline\n",
        "                                #   \"wear_observation\"     = AR(1) + observation-level wear model\n",
        "                                #   \"wear_latent\"          = AR(1) + latent wear-state model\n",
        "                                #   \"ar2_wear_observation\" = AR(2) + observation-level wear model\n",
        "                                #   \"ar2_wear_latent\"      = AR(2) + latent wear-state model\n",
        "                                #   \"arma_aic\"             = ARMA(p, q) chosen by AIC for each participant\n",
        "  pooling_mode: \"all\"  # single mode, comma-separated string, YAML list, or \"all\"\n",
        "                                # pooling_mode options:\n",
        "                                #   \"unit_specific\"\n",
        "                                #   \"global_shared_k\"\n",
        "                                #   \"partial_pooled_k\"\n",
        "                                #   \"all\" = all three pooling modes above\n",
        "                                # example YAML list:\n",
        "                                # pooling_mode:\n",
        "                                #   - \"unit_specific\"\n",
        "                                #   - \"global_shared_k\"\n",
        "                                #   - \"partial_pooled_k\"\n",
        "  covariate_mode: \"none\"\n",
        "  mask_regime: \"random_hours\"\n",
        "  missing_fraction: 0.20\n",
        "  mask_seed: 531\n",
        "  n_mask_replicates: 1\n",
        "  fit_scope: \"masked_only\"      # null = use RL preset\n",
        "                                # fit_scope options:\n",
        "                                #   \"unmasked_only\"\n",
        "                                #   \"masked_only\"\n",
        "                                #   \"both\"\n",
        "                                #   \"benchmarks_from_cache_only\"\n",
        "  section_scope: \"all\"\n",
        "  global_seed: 531\n",
        "  panel_chunk_size: null       # participant batch size for panel fits; null = RL preset default\n",
        "  stage1_starts: null\n",
        "  stage2_starts: null\n",
        "  stage1_keep_top: null\n",
        "  stage2_keep_top: null\n",
        "  stage1_particles: null\n",
        "  stage2_particles: null\n",
        "  stage1_if2_iterations: null\n",
        "  stage2_if2_iterations: null\n",
        "  stage1_cooling_fraction: null\n",
        "  stage2_cooling_fraction: null\n",
        "  stage1_rw_sd_scale: null\n",
        "  stage2_rw_sd_scale: null\n",
        "  cooling_fraction: null       # shared fallback for both stages when stage-specific cooling is null\n",
        "  rw_sd_scale: null            # shared fallback for both stages when stage-specific RW scale is null\n",
        "  stage1_eval_particles: null\n",
        "  stage2_eval_particles: null\n",
        "  stage1_eval_reps: null\n",
        "  stage2_eval_reps: null\n",
        "  stage1_fresh_random_starts: null\n",
        "  stage2_fresh_random_starts: null\n",
        "  stage1_jittered_restarts: null\n",
        "  stage2_jittered_restarts: null\n",
        "  # Global search window overrides. Leave null to use the built-in defaults.\n",
        "  # Only parameters active in the selected model / pooling mode matter.\n",
        "  phi_window_low: null\n",
        "  phi_window_high: null\n",
        "  phi1_window_low: null\n",
        "  phi1_window_high: null\n",
        "  phi2_window_low: null\n",
        "  phi2_window_high: null\n",
        "  phi24_window_low: null\n",
        "  phi24_window_high: null\n",
        "  sigma_window_low: null\n",
        "  sigma_window_high: null\n",
        "  k_fitbit_window_low: null\n",
        "  k_fitbit_window_high: null\n",
        "  log_k_fitbit_window_low: null\n",
        "  log_k_fitbit_window_high: null\n",
        "  mu_log_k_fitbit_window_low: 0.2\n",
        "  mu_log_k_fitbit_window_high: 2.0\n",
        "  log_tau_log_k_fitbit_window_low: -1.7\n",
        "  log_tau_log_k_fitbit_window_high: 1.0\n",
        "  eta_wear_lag1_window_low: null\n",
        "  eta_wear_lag1_window_high: null\n",
        "  wear_phi_window_low: null\n",
        "  wear_phi_window_high: null\n",
        "  wear_sigma_window_low: null\n",
        "  wear_sigma_window_high: null\n",
        "execute:\n",
        "  echo: false\n",
        "format:\n",
        "  pdf:\n",
        "    include-in-header:\n",
        "      text: |\n",
        "        \\RedeclareSectionCommand[beforeskip=0.5em, runin=false, afterskip=0em]{section}\n",
        "        \\usepackage{fullpage}\n",
        "        \\usepackage{wrapfig}\n",
        "number-sections: true\n",
        "---"
      ],
      "id": "64928e1e"
    },
