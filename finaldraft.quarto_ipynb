        "        \"wear_sigma_window_low\",\n",
        "        \"wear_sigma_window_high\",\n",
        "    ]\n",
        "    injected = {key: globals()[key] for key in parameter_keys if key in globals()}\n",
        "    if injected:\n",
        "        return injected\n",
        "    try:\n",
        "        raw = dict(params)\n",
        "        if raw:\n",
        "            return raw\n",
        "    except Exception:\n",
        "        pass\n",
        "    if not REPORT_QMD_PATH.exists():\n",
        "        return {}\n",
        "    try:\n",
        "        text = REPORT_QMD_PATH.read_text(encoding=\"utf-8\")\n",
        "        if not text.startswith(\"---\"):\n",
        "            return {}\n",
        "        end_idx = text.find(\"\\n---\", 4)\n",
        "        if end_idx < 0:\n",
        "            return {}\n",
        "        frontmatter = yaml.safe_load(text[4:end_idx]) or {}\n",
        "        params_block = frontmatter.get(\"params\", {})\n",
        "        return dict(params_block) if isinstance(params_block, dict) else {}\n",
        "    except Exception:\n",
        "        return {}\n",
        "\n",
        "\n",
