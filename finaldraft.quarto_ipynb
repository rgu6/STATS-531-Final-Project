        "        \"missing_fraction\",\n",
        "        \"mask_seed\",\n",
        "        \"n_mask_replicates\",\n",
        "        \"fit_scope\",\n",
        "        \"section_scope\",\n",
        "        \"global_seed\",\n",
        "        \"panel_chunk_size\",\n",
        "        \"stage1_starts\",\n",
        "        \"stage2_starts\",\n",
        "        \"stage1_keep_top\",\n",
        "        \"stage2_keep_top\",\n",
        "        \"stage1_particles\",\n",
        "        \"stage2_particles\",\n",
        "        \"stage1_if2_iterations\",\n",
        "        \"stage2_if2_iterations\",\n",
        "        \"stage1_cooling_fraction\",\n",
        "        \"stage2_cooling_fraction\",\n",
        "        \"stage1_rw_sd_scale\",\n",
        "        \"stage2_rw_sd_scale\",\n",
        "        \"cooling_fraction\",\n",
        "        \"rw_sd_scale\",\n",
        "        \"stage1_eval_particles\",\n",
        "        \"stage2_eval_particles\",\n",
        "        \"stage1_eval_reps\",\n",
        "        \"stage2_eval_reps\",\n",
        "        \"stage1_fresh_random_starts\",\n",
        "        \"stage2_fresh_random_starts\",\n",
        "        \"stage1_jittered_restarts\",\n",
        "        \"stage2_jittered_restarts\",\n",
