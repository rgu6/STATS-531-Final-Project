        "execute:\n",
        "  echo: false\n",
        "format:\n",
        "  pdf:\n",
        "    include-in-header:\n",
        "      text: |\n",
        "        \\RedeclareSectionCommand[beforeskip=0.5em, runin=false, afterskip=0em]{section}\n",
        "        \\usepackage{fullpage}\n",
